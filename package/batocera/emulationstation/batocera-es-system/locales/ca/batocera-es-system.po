#. TRANSLATION: dolphin
msgctxt "game_options"
msgid ""
"Enable Gamecube boot animation and BIOS access (requires IPL.bin BIOS in "
"appropriate user directory)."
msgstr ""
"Activar l’animació d’arrencada i l’accès a BIOS (requereix BIOS IPL.bin al "
"corresponent directori d’usuari)."

#. TRANSLATION: libretro/dosbox_pure
msgctxt "game_options"
msgid ""
"Enable Gravis Utrasound emulation. Ensure the ULTRASND folder is in the root "
"of your <game>.pc rom folder."
msgstr ""
"Activar l’emulació de Gravis Ultrasound. Assegura’t que la carpeta ULTRASND "
"hi és a l’arrel de la carpeta de <joc>.pc."

#. TRANSLATION: shadps4
msgctxt "game_options"
msgid "Enable High Dynamic Range if your display supports it."
msgstr "Activa l’Alt Rang Dinàmic (HDR) si la teva pantalla ho suporta."

#. TRANSLATION: melonds
msgctxt "game_options"
msgid ""
"Enable MelonDS to display over two screens. Some related screen options will "
"be ignored."
msgstr ""
"Indica a MelonDS que mostri en dos pantalles. Algunes opcions de pantalla "
"seran ignorades."

#. TRANSLATION: pcsx2
msgctxt "game_options"
msgid "Enable No-interlacing Patches."
msgstr "Activa les corrección per a no entrellaçar."

#. TRANSLATION: moonlight
msgctxt "game_options"
msgid "Enable QOS settings to optimize for internet or local network."
msgstr ""
"Habilita QoS (qualitat de servei) per a optimitzar internet o la xarxa local."

#. TRANSLATION: libretro/stella
msgctxt "game_options"
msgid "Enable TV-like filtering / effects."
msgstr "Activa els filtres / efectes de simulació de TV."

#. TRANSLATION: model2emu
msgctxt "game_options"
msgid "Enable X-Input mode for Xbox type controllers."
msgstr "Activa el mode X-Input per a comandaments de tipus Xbox."

#. TRANSLATION: openjkdf2
msgctxt "game_options"
msgid "Enable aiming crosshair."
msgstr "Activa punt de mira."

#. TRANSLATION: openjkdf2
msgctxt "game_options"
msgid "Enable auto aiming."
msgstr "Activar apuntar automàticament."

#. TRANSLATION: redream
msgctxt "game_options"
msgid "Enable auto frameskipping for performance on lower-end systems."
msgstr ""
"Habilitar salt de quadres automàtic per a guanyar rendiment als sistemes de "
"baixes prestacions."

#. TRANSLATION: xenia, xenia-canary
msgctxt "game_options"
msgid ""
"Enable cache mount. Can improve performance and compatibility in some games."
msgstr ""
"Activa el muntatge de memòria cau. Pot millorar el rendiment i "
"compatibilitat en alguns jocs."

#. TRANSLATION: dolphin, rpcs3
msgctxt "game_options"
msgid "Enable controller rumble capabilities if supported by the controller."
msgstr "Habilita les funcions de vibració si el comandament ho suporta."

#. TRANSLATION: supermodel
msgctxt "game_options"
msgid "Enable crosshairs in shooting games for the selected players."
msgstr "Habilitar punts de mira al jocs de tir per als jugadors seleccionats."

#. TRANSLATION: libretro/virtualjaguar
msgctxt "game_options"
msgid "Enable for Doom to run at its correct resolution."
msgstr "Habilitar per a córrer Doom en la seva resolució correcta."

#. TRANSLATION: ppsspp
msgctxt "game_options"
msgid "Enable for more fluidity, disable if screen tearing."
msgstr "Habilitar per a més fluïdesa, deshabilitar si es produeix tearing."

#. TRANSLATION: lindbergh-loader
msgctxt "game_options"
msgid "Enable free play for supported games."
msgstr "Activar jugar gratuïtament per als jocs que ho suportin."

#. TRANSLATION: openjkdf2
msgctxt "game_options"
msgid "Enable full subtitles on cutscenes."
msgstr "Activar tots els subtítols a les cinemàtiques."

#. TRANSLATION: model2emu
msgctxt "game_options"
msgid "Enable full-screen antialiasing in Direct3D."
msgstr "Habilitar antialiàsing de pantalla completa a Direct3D."

#. TRANSLATION: wine
msgctxt "game_options"
msgid ""
"Enable gamepad HID raw access. This allow modern game to use special gamepad "
"features (like gyroscope for example), but can break older games with x-"
"input support only."
msgstr ""
"Activar l’accès en cru als comandaments HID. Això permet als jocs moderns "
"usar funcions especials (com giroscopi, per exemple), però pot rencar els "
"jocs més antics que només suporten x-input."

#. TRANSLATION: cemu
msgctxt "game_options"
msgid ""
"Enable gamepad view for games that have interaction across two screens. Use "
"Hotkey+R2 to switch screens."
msgstr ""
"Habilita la vista del comandament per a jocs que tenen interacció amb les 2 "
"pantalles. Useu Drecera+R2 per a intercanviar-les."

#. TRANSLATION: openjkdf2
msgctxt "game_options"
msgid "Enable high dots per inch."
msgstr "Activa alta resolució."

#. TRANSLATION: sonic2013, soniccd
msgctxt "game_options"
msgid "Enable high quality effects for special stages."
msgstr "Habilitar efectes d’alta qualitat a etapes especials."

#. TRANSLATION: libretro/puae, libretro/puae2021
msgctxt "game_options"
msgid "Enable launching pre-installed WHDLoad installs."
msgstr "Habilitar arrencar pre-instalacions de WHDLoad."

#. TRANSLATION: openjkdf2
msgctxt "game_options"
msgid "Enable lightsaber auto-camera."
msgstr "Activa la càmera automàtica del sable làser."

#. TRANSLATION: mame
msgctxt "game_options"
msgid ""
"Enable mouse input for trackballs, spinners, lightguns (if no gun "
"connected), and similar controls"
msgstr ""
"Habilita l’entrada de ratolí per a trackballs, spinners, pistoles de llum "
"(si no n’hi ha cap connectada), i comandaments similars"

#. TRANSLATION: cemu
msgctxt "game_options"
msgid "Enable mouse input to simulate touchscreen."
msgstr "Habilita entrada de ratolí per a simular pantalla tàctil."

#. TRANSLATION: cemu
msgctxt "game_options"
msgid "Enable notifications of cache, controller events etc."
msgstr "Habilitar notificacions de memória cau, events de controlador, etc."

#. TRANSLATION: corsixth
msgctxt "game_options"
msgid "Enable or Disable Intro movie (Enabled by default)."
msgstr "Activa o desactiva cinemàtica inicial (Activat per defecte)."

#. TRANSLATION: xenia-canary
msgctxt "game_options"
msgid ""
"Enable or disable Xenia patches. These patches can fix graphics problems in "
"some games."
msgstr ""
"Activa o desactiva les correccions de Xenia. Aquestes, poden corretgir "
"problemes gràfics en alguns jocs."

#. TRANSLATION: hypseus-singe
msgctxt "game_options"
msgid ""
"Enable or disable bezels being added when content is a 4:3 aspect with a "
"widescreen display."
msgstr ""
"Activa o desactiva l’adició de motlures quan el contingut té aspecte 4:3 en "
"una pantalla panoràmica."

#. TRANSLATION: libretro/mame, mame
msgctxt "game_options"
msgid "Enable or disable high score saving"
msgstr "Habilitar desat de puntuacions"

#. TRANSLATION: libretro/mame, libretro/mamevirtual, mame
msgctxt "game_options"
msgid "Enable per-game custom configuration via MAME menu."
msgstr "Habilitar configuració personalitzada per joc mitjançant el menú MAME."

#. TRANSLATION: libretro/stella
msgctxt "game_options"
msgid "Enable phosphor mode (motion blur) for flickering effects."
msgstr ""
"Activa el mode fósfor (dimuminat per moviment) per efectes de parpelleig."

#. TRANSLATION: supermodel
msgctxt "game_options"
msgid "Enable proper quad rendering (for higher end systems)."
msgstr ""
"Habilitar renderització quàdrupla (per a sistemes d’altes prestacions)."

#. TRANSLATION: openjkdf2
msgctxt "game_options"
msgid "Enable rotation on overlay map."
msgstr "Activa la rotació en la superposició de mapa."

#. TRANSLATION: model2emu
msgctxt "game_options"
msgid "Enable scanlines for roms that support it."
msgstr "Habilitat scanlines en les roms que ho suporten."

#. TRANSLATION: mupen64plus
msgctxt "game_options"
msgid ""
"Enable second audio limiter. Improves audio quality at the cost of "
"performance."
msgstr ""
"Habilitar segon limitador d’àudio. Millora la qualitat d’àudio a cost de "
"rendiment."

#. TRANSLATION: libretro/opera
msgctxt "game_options"
msgid "Enable shared saves for multi-disc games"
msgstr "Habilita els desats compartits per a jocs multi-disc"

#. TRANSLATION: wine
msgctxt "game_options"
msgid "Enable support for Chinese, Japanese and Korean input methods."
msgstr "Activa el suport de mètodes d’entrada per Xinès, Japonès i Koreà."

#. TRANSLATION: libretro/atari800
msgctxt "game_options"
msgid "Enable the BASIC interpreter. Some games need this."
msgstr "Activa l’intèrpret de BASIC. Alguns jocs ho necessiten."

