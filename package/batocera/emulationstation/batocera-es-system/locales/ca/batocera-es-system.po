msgstr "Usar llistes de programari MAME per a identificar la ROM"

#. TRANSLATION: libretro/genesisplusgx, libretro/genesisplusgx-expanded, libretro/picodrive
msgctxt "game_options"
msgid ""
"Use Megadrive to automap inputs for a Megadrive style controller with a 6 "
"button layout."
msgstr ""
"Usar Megadrive per assignar automàticament les entrades per a un comandament "
"d’estil Megadrive amb disposició de 6 botons."

#. TRANSLATION: catacomb.keys
msgctxt "keys_files"
msgid "Use Potion"
msgstr "Usar poció"

#. TRANSLATION: dolphin
msgctxt "game_options"
msgid ""
"Use SSAA instead of MSAA for anti-aliasing. SSAA may look better but has a "
"higher performance cost."
msgstr ""
"Usa SSAA en lloc de MSAA per anit-aliàsing. SSAA pot semblar millor, però té "
"més cost de rendiment."

#. TRANSLATION: libretro/mame, libretro/mamevirtual, libretro/same_cdi
msgctxt "game_options"
msgid "Use a custom MAME config, do not overwrite config on launch."
msgstr ""
"Usa una configuració MAME personalitzada. No sobreescriu la configuració en "
"l’arrencada."

#. TRANSLATION: libretro/dice
msgctxt "game_options"
msgid "Use a specific mouse for Paddle 1, chosen by Port 1's Mouse Index."
msgstr ""
"Usar un ratolí específic pel botó rotatori (paddle) 1, escollit com índex de "
"ratolí del Port 1."

#. TRANSLATION: libretro/dice
msgctxt "game_options"
msgid "Use a specific mouse for Paddle 2, chosen by Port 2's Mouse Index."
msgstr ""
"Usar un ratolí específic pel botó rotatori (paddle) 2, escollit com índex de "
"ratolí del Port 2."

#. TRANSLATION: libretro/dice
msgctxt "game_options"
msgid "Use a specific mouse for Paddle 3, chosen by Port 3's Mouse Index."
msgstr ""
"Usar un ratolí específic pel botó rotatori (paddle) 3, escollit com índex de "
"ratolí del Port 3."

#. TRANSLATION: libretro/dice
msgctxt "game_options"
msgid "Use a specific mouse for Paddle 4, chosen by Port 4's Mouse Index."
msgstr ""
"Usar un ratolí específic pel botó rotatori (paddle) 4, escollit com índex de "
"ratolí del Port 4."

#. TRANSLATION: libretro/stella
msgctxt "game_options"
msgid "Use absolute analog input for paddles."
msgstr "Usa entrades analògiques absolutes pels botons rotatoris (paddles)."

#. TRANSLATION: libretro/atari800
msgctxt "game_options"
msgid "Use an alternate resolution. Some games need this."
msgstr "Usar una resolució alternativa. Alguns jocs ho necessiten."

#. TRANSLATION: hypseus-singe
msgctxt "game_options"
msgid "Use controller settings manually defined in custom.ini."
msgstr ""
"Utilitza la configuració del comandament definits manualment a custom.ini."

#. TRANSLATION: model2emu
msgctxt "game_options"
msgid ""
"Use if you're having graphical issues or GPU problems with this emulator."
msgstr ""
"Useu si s’experimenten defectes gràfics o problemes de GPU amb aquest "
"emulador."

#. TRANSLATION: quake2.keys
msgctxt "keys_files"
msgid "Use item"
msgstr "Usar objecte"

#. TRANSLATION: libretro/melonds
msgctxt "game_options"
msgid "Use language and username from the NDS Firmware"
msgstr "Usar idioma i nom d'usuari del firmware de la NDS"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Use light guns instead of pads if light guns are connected."
msgstr "Usar pistoles de llum enlloc de comandaments, si estàn connectades."

#. TRANSLATION: corsixth
msgctxt "game_options"
msgid "Use new graphics created from CorsixTH project"
msgstr "Usa els nous gràfics creats al projecte CorsixTH"

#. TRANSLATION: libretro/neocd
msgctxt "game_options"
msgid "Use one save file per game."
msgstr "Usar un fitxer de desat per joc."

#. TRANSLATION: shared
msgctxt "game_options"
msgid ""
"Use preemptive frames instead of run-ahead. Only runs ahead when controller "
"state changes."
msgstr ""
"Usa predicció de quadres enlloc d’anticipar-los. Només funciona per davant "
"quan el l’estat del comandament canvia."

#. TRANSLATION: libretro/mame, libretro/mamevirtual
msgctxt "game_options"
msgid ""
"Use the same art paths as standalone MAME - not recommended if using "
"decorations or shaders."
msgstr ""
"Usar la mateixa ruta d’art que l’emulador individual MAME - No recomanat si "
"s’usen decoracions o shaders."

#. TRANSLATION: libretro/dice
msgctxt "game_options"
msgid ""
"Use the system mouse pointer as paddle controller 1.  Does not let you "
"choose a specific mouse if you have several."
msgstr ""
"Usa el punter del ratolí com a botó rotatori (paddle) 1. No permet escollir "
"un ratolí específic si tens més d’un."

#. TRANSLATION: libretro/melondsds
msgctxt "game_options"
msgid ""
"Use this to play online with custom servers that reimplement the "
"discontinued Nintendo Wi-Fi."
msgstr ""
"Usa’l per jugar en línea amb servidors personalitzats que reimplementen la "
"Nintendo Wi-Fi."

#. TRANSLATION: libretro/scummvm
msgctxt "game_options"
msgid "Use to eliminate cursor drift/unwanted input."
msgstr "Usar per eliminar la desviació de cursor o entrades no desitjades."

#. TRANSLATION: libretro/mupen64plus-next, libretro/parallel_n64
msgctxt "game_options"
msgid ""
"Use to eliminate joystick drift/unwanted input. Effects all controllers."
msgstr ""
"Usar per eliminar efecte drift (moviment involuntari). Afecta a tots els "
"comandaments."

#. TRANSLATION: libretro/mupen64plus-next, libretro/parallel_n64
msgctxt "game_options"
msgid ""
"Use to make joystick movement more or less sensitive. Effects all "
"controllers."
msgstr ""
"Usar per fer que el moviement de la palanca no sigui tan sensible. Afecta a "
"tots els comandaments."

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Use wheels instead of pads if wheels are connected."
msgstr "Usa volant en lloc dels comandaments, si està connectat."

#. TRANSLATION: libretro/vb
msgctxt "game_options"
msgid "Use your physical anaglypth 3D glasses!"
msgstr "Usa les teves ulleres anàglif 3D físiques!"

#. TRANSLATION: libretro/mupen64plus-next, libretro/parallel_n64, mupen64plus
msgctxt "game_options"
msgid "Useful for N64 style controllers."
msgstr "Útil per a comandaments d’estil N64."

#. TRANSLATION: libretro/mupen64plus-next, libretro/parallel_n64, mupen64plus
msgctxt "game_options"
msgid ""
"Useful for N64 style controllers. Limited hotkeys for controllers without "
