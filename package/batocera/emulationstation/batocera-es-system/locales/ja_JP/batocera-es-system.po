msgctxt "game_options"
msgid "SHADER SET"
msgstr "シェーダー設定"

#. TRANSLATION: shared
msgctxt "game_options"
msgid ""
"Disabled if using a shader set or the output display matches the game's "
"resolution."
msgstr ""
"シェーダーセットを使用、または出力表示がゲーム解像度と同じ場合は無効になりま"
"す"

#. TRANSLATION: hypseus-singe, play, shared
msgctxt "game_options"
msgid "SMOOTH GAMES (BILINEAR FILTERING)"
msgstr "スムーズゲーム（バイリニアフィルタリング）"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Only increase the image size in integer multiples."
msgstr "画像サイズは、整数倍でのみ増やします"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "INTEGER SCALING (PIXEL PERFECT)"
msgstr "整数スケール (ピクセルを正方形表示)"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "DECORATIONS"
msgstr "ベゼル(ゲーム画面外装飾表示)"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "DECORATION SET"
msgstr "ベゼル設定"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "STRETCH BEZELS (4K & ULTRAWIDE)"
msgstr "画面に合わせる(4K＆ウルトラワイド)"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Show context-sensitive info over the game."
msgstr "ゲーム全体でコンテキスト依存の情報を表示します"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "HEADS UP DISPLAY"
msgstr "ヘッドアップディスプレイ"

#. TRANSLATION: citron, dolphin, dolphin_triforce, drastic, fallout1-ce, ...
msgctxt "game_options"
msgid "None"
msgstr "なし"

