msgctxt "game_options"
msgid "Shader Interpreter only"
msgstr "シェーダー インタープリターのみ"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Only applicable when either Async Shader mode is set."
msgstr "非同期シェーダー モードが設定されている場合にのみ適用されます"

