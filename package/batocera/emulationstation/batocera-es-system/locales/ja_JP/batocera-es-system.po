msgstr "映像"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "16:9 (default)"
msgstr "16:9 (標準)"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "RENDER"
msgstr "レンダラ"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Most games already have an internal framelimit. Minor performance cost."
msgstr "多くのゲームには内部フレーム制限があります。動作を少し軽くします"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "ADDITIONAL FRAMELIMIT"
msgstr "フレーム制限の追加"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Off (faster, unstable)"
msgstr "オフ（より速いが不安定）"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "ANISOTROPIC FILTER"
msgstr "異方性フィルター"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Can improve performance at the expense of graphics accuracy."
msgstr "グラフィックスの精度を下げて性能を向上させます"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "ZCULL ACCURACY"
msgstr "ZCULL 精度"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Precise (Slowest)(Default)"
msgstr "正確 (最も遅い)(標準)"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Approximate (Fast)"
msgstr "近似（高速）"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Relaxed (Fastest)"
msgstr "リラックス (最速)"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid ""
"Controls precision of generated shaders. Low quality can improved "
"performance."
msgstr ""
"生成されたシェーダーの精度を制御します。品質を低くすると、\n"
"動作が向上する可能性があります"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "SHADER QUALITY"
msgstr "シェーダー品質"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Ultra"
msgstr "ウルトラ"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "High (Default)"
msgstr "高 (標準)"

#. TRANSLATION: cgenius, rpcs3
msgctxt "game_options"
msgid "Choose your preferred render resolution."
msgstr "レンダリング解像度を選択します"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "RENDER RESOLUTION (SCALING)"
msgstr "レンダリング解像度 (スケーリング)"

#. TRANSLATION: rpcs3, xenia-canary
msgctxt "game_options"
msgid "1280x720 (Default)"
msgstr "1280x720 (標準)"

