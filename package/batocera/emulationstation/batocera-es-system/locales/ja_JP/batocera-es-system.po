msgstr "100ミリ秒 (標準)"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "120ms"
msgstr "120ミリ秒"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "140ms"
msgstr "140ミリ秒"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "160ms"
msgstr "160ミリ秒"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "180ms"
msgstr "180ミリ秒"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "200ms"
msgstr "200ミリ秒"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "220ms"
msgstr "220ミリ秒"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "240ms"
msgstr "240ミリ秒"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid ""
"Reduces crackle and stutter further, but may cause a very noticeable "
"reduction in audio quality on slower CPUs."
msgstr ""
"パチパチ音とカクつきをさらに減らしますが、遅い CPU では音質が著しく低下する可"
