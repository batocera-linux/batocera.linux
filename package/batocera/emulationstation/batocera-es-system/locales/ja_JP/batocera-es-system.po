msgctxt "game_options"
msgid "Performance"
msgstr "性能"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "HEADS UP DISPLAY CORNER"
msgstr "ヘッドアップディスプレイ位置"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "TOP LEFT (NW)"
msgstr "左上（←↑）"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "TOP RIGHT (NE)"
msgstr "右上（→↑）"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "BOTTOM RIGHT (SE)"
msgstr "右下（→↓）"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "BOTTOM LEFT (SW)"
msgstr "左下（←↓）"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Show an image overlaid on top of the bezel."
msgstr "ベゼル上にイメージ画像を表示します"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "SHOW TATTOO OVER BEZEL"
msgstr "ベゼル上にイメージ画像を表示"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "NO"
msgstr "いいえ"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "SYSTEM CONTROLLERS"
msgstr "機種 コントローラー"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "CUSTOM IMAGE"
msgstr "カスタム画像"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "TATTOO CORNER"
msgstr "イメージ画像表示位置"

