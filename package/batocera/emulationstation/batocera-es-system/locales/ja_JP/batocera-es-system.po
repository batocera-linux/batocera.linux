msgstr "2 スレッド"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "3 threads"
msgstr "3 スレッド"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "4 threads"
msgstr "4 スレッド"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "5 threads"
msgstr "5 スレッド"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "6 threads"
msgstr "6 スレッド"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid ""
"May provide performance gain on CPUs with low core/thread count at the "
"expense of possible broken timings."
msgstr ""
"コア/スレッド数が少ない CPU では、タイミングが\n"
"壊れる可能性があるが、パフォーマンスが向上する可能性があります"

