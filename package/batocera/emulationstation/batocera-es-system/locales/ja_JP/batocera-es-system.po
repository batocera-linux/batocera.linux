msgctxt "game_options"
msgid "Config"
msgstr "コンフィグ"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Square pixel"
msgstr "正方形ピクセル"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Core provided"
msgstr "コア設定"

#. TRANSLATION: libretro/gambatte, libretro/mesen, libretro/stella, shared
msgctxt "game_options"
msgid "Custom"
msgstr "その他カスタマイズ"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Store past states to rewind to in realtime, if the core supports it."
msgstr ""
"コアが対応している場合は、過去の状態を保存して\n"
"リアルタイムで巻き戻します"

#. TRANSLATION: duckstation, shared
msgctxt "game_options"
msgid "REWIND"
msgstr "巻き戻し"

#. TRANSLATION: azahar, cannonball, dolphin_triforce, drastic, duckstation, ...
msgctxt "game_options"
msgid "On"
msgstr "使用"

#. TRANSLATION: azahar, cannonball, cemu, dolphin, dolphin_triforce, ...
msgctxt "game_options"
msgid "Off"
msgstr "使用しない"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "Load latest save state on game launch and save state when exiting game."
msgstr ""
"ゲーム開始時にステートを読込み、終了時にステートセーブします\n"
"(ステートセーブ保存方法－「ゲームごとにセーブ」に設定)"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "AUTO SAVE/LOAD ON GAME LAUNCH"
msgstr "自動ステート読込でゲームを開始"

#. TRANSLATION: shared
msgctxt "game_options"
msgid "GAME RENDERING & SHADERS"
msgstr "ゲーム レンダリング & シェーダー"

