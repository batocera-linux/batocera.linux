msgctxt "game_options"
msgid "FidelityFX Super Resolution"
msgstr "FidelityFX 超解像度"

#. TRANSLATION: rpcs3
msgctxt "game_options"
msgid "Only Async (skip draw) avoids freezing while compiling shaders."
msgstr ""
"シェーダーコンパイル中のフリーズ回避は、非同期（スキップドロー）のみです"

