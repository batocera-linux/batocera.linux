+void App::MapConfiguredGamepads() {
+    int num_gamepads = 0;
+    SDL_JoystickID* joysticks = SDL_GetJoysticks(&num_gamepads);
+    if (!joysticks) {
+        return;
+    }
+
+    for (int port = 0; port < 2; ++port) {
+        const auto& path_str = m_settings.input.ports[port].devicePath.string();
+        if (path_str.empty()) {
+            continue;
+        }
+
+        for (int i = 0; i < num_gamepads; ++i) {
+            SDL_JoystickID instanceID = joysticks[i];
+
+            // Avoid mapping the same physical gamepad to multiple ports
+            if (m_gamepadPlayerIndices.Contains(instanceID)) {
+                continue;
+            }
+
+            const char* current_path = SDL_GetJoystickPathForID(instanceID);
+            if (current_path && path_str == current_path) {
+                SDL_Gamepad* gamepad = SDL_OpenGamepad(instanceID);
+                if (gamepad) {
+                    m_gamepadPlayerIndices.ForceMapping(instanceID, port);
+                    m_gamepads[instanceID] = gamepad;
+                    m_context.inputContext.ConnectGamepad(port);
+                    devlog::debug<grp::base>("Device {} mapped to Port {} (Player Index {})", current_path, port + 1, port);
+                }
+                break; // Stop looking for devices for this port, move to next port
+            }
+        }
+    }
+
+    SDL_free(joysticks);
+}
+
 } // namespace app
