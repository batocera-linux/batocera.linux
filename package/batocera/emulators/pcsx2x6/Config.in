config BR2_PACKAGE_PCSX2X6
    bool "pcsx2x6"
    depends on BR2_x86_64
    depends on BR2_PACKAGE_XORG7
    select BR2_PACKAGE_ALSA_LIB  
    select BR2_PACKAGE_BATOCERA_QT6  
    select BR2_PACKAGE_BR2_PACKAGE_FMT  
    select BR2_PACKAGE_DEJAVU
    select BR2_PACKAGE_ECM
    select BR2_PACKAGE_FREETYPE
    select BR2_PACKAGE_KDDOCKWIDGETS 
    select BR2_PACKAGE_LIBAIO  
    select BR2_PACKAGE_LIBBACKTRACE  
    select BR2_PACKAGE_LIBCURL  
    select BR2_PACKAGE_LIBGTK3  
    select BR2_PACKAGE_LIBPCAP  
    select BR2_PACKAGE_LIBPNG  
    select BR2_PACKAGE_LIBSAMPLERATE  
    select BR2_PACKAGE_LIBSOUNDTOUCH
    select BR2_PACKAGE_PLUTOSVG
    select BR2_PACKAGE_PORTAUDIO
    select BR2_PACKAGE_RAPIDYAML
    select BR2_PACKAGE_SDL3  
    select BR2_PACKAGE_SHADERC  
    select BR2_PACKAGE_VULKAN_HEADERS    if BR2_PACKAGE_BATOCERA_VULKAN  
    select BR2_PACKAGE_VULKAN_LOADER     if BR2_PACKAGE_BATOCERA_VULKAN  
    select BR2_PACKAGE_WEBP  
    select BR2_PACKAGE_WXWIDGETS  
    select BR2_PACKAGE_YAML_CPP  
    select BR2_PACKAGE_ZLIB
    help
      PCSX2X6 is a fork of PCSX2 to emulate NAMCO System246 and System256 arcade units.
      
      https://github.com/PS2Homebrew-arcade/pcsx2x6
