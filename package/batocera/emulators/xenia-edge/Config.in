config BR2_PACKAGE_XENIA_EDGE
    bool "xenia-edge"
    depends on BR2_x86_64
    select BR2_PACKAGE_SDL2
    select BR2_PACKAGE_VULKAN_HEADERS
    select BR2_PACKAGE_VULKAN_LOADER
    select BR2_PACKAGE_LZ4
    select BR2_PACKAGE_ALSA_LIB
    select BR2_PACKAGE_PYTHON_TOML
    select BR2_PACKAGE_QT6BASE
    help
        Xenia is an open source research project for emulating Xbox 360 games on modern PCs.
        Xenia Edge is the native Linux port, running without Wine using Vulkan for graphics
        and ALSA/SDL for audio.

        https://github.com/has207/xenia-edge
