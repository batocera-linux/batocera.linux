in C++20 strict mode (clang 18+ / GCC 13+).

Signed-off-by: Batocera Linux Team <batocera@batocera.linux>
---
 src/xenia/kernel/xam/xdbf/spa_info.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/xenia/kernel/xam/xdbf/spa_info.h b/src/xenia/kernel/xam/xdbf/spa_info.h
index 1111111..2222222 100644
--- a/src/xenia/kernel/xam/xdbf/spa_info.h
+++ b/src/xenia/kernel/xam/xdbf/spa_info.h
@@ -13,6 +13,7 @@
 #include "xenia/kernel/xam/xdbf/xdbf_io.h"

+#include <algorithm>
 #include <map>
 #include <numeric>
