+			input_buf[0xA0 + g * 4 + 1] = ax8; // X low byte (fine detail)
+			input_buf[0xA2 + g * 4 + 0] = hy;  // Y high byte
+			input_buf[0xA2 + g * 4 + 1] = ay8; // Y low byte
