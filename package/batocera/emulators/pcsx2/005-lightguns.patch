+	int event_isNumber(const char *s) {
+	  int n;
+	  if(strlen(s) == 0) return 0;
+	  for(n=0; n<strlen(s); n++) {
+	    if(!(s[n] >= '0' && s[n] <= '9')) return 0;
+	  }
