+	int event_strcmp_events(const char* x, const char* y) {
+	  int n, common, is_number, a, b;
+	  n=0;
+	  while(x[n] == y[n] && x[n] != '\0' && y[n] != '\0') n++;
+	  common = n;
+	  is_number = 1;
+	  if(event_isNumber(x+common) == 0) is_number = 0;
+	  if(event_isNumber(y+common) == 0) is_number = 0;
+	  if(is_number == 1) {
+	    a = atoi(x+common); b = atoi(y+common);
+	    if(a == b) return 0;
+	    if(a < b) return -1;
+	    return 1;
+	  } else {
+	    return strcmp(x, y);
+	  }
+	}
