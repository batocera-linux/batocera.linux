config BR2_PACKAGE_LIBZEDMD
    bool "libzedmd"
    select BR2_PACKAGE_CARGS
    select BR2_PACKAGE_LIBSERIALPORT
    select BR2_PACKAGE_SOCKPP
    select BR2_PACKAGE_LIBFRAMEUTIL
    select BR2_PACKAGE_LIBGPIOD2 if BR2_aarch64 && BR2_TOOLCHAIN_HEADERS_AT_LEAST_5_10
    select BR2_PACKAGE_LIBGPIOD  if BR2_aarch64 && !BR2_TOOLCHAIN_HEADERS_AT_LEAST_5_10 && BR2_TOOLCHAIN_HEADERS_AT_LEAST_4_8
    help
      ZeDMD communication library.
      
      https://github.com/PPUC/libzedmd
