#
# Updated detection for batocera and minor tweaks by @dmanlfc
#
# This script will update the ABL on the internal UFS.

set -euo pipefail

# Fallback to interactive mode (0) if not defined
NON_INTERACTIVE="${NON_INTERACTIVE:-0}"

# Normalize non-interactive value to a strict integer (0 or 1)
if [ "$NON_INTERACTIVE" = "true" ] || [ "$NON_INTERACTIVE" = "yes" ] || [ "$NON_INTERACTIVE" = "1" ]; then
    NON_INTERACTIVE=1
else
    NON_INTERACTIVE=0
fi

# ---- Get Device Architecture ----
ARCH_FILE="/usr/share/batocera/batocera.arch"
if [ -f "$ARCH_FILE" ]; then
    HW_DEVICE=$(cat "$ARCH_FILE" | tr '[:lower:]' '[:upper:]')
else
    echo "Error: Architecture file $ARCH_FILE not found!"
    exit 1
fi

# add SM6115 & SM8650 for future device support
case "$HW_DEVICE" in
  SM6115|SM8250|SM8550|SM8650)
    ;;
  *)
    echo "This script is not compatible with device: $HW_DEVICE"
    exit 1
    ;;
esac

ABL_DIR="/usr/share/bootloader/rocknix_abl"
ELF="${ABL_DIR}/abl_signed-${HW_DEVICE}.elf"
SHA256SUM="${ABL_DIR}/abl_signed-${HW_DEVICE}.elf.sha256"

ABL_A="/dev/disk/by-partlabel/abl_a"
ABL_B="/dev/disk/by-partlabel/abl_b"

# Ensure the ABL directory exists
mkdir -p "$ABL_DIR"

# ---- GitHub Online Check Logic ----
if [[ "${1:-}" == "--check-online" ]]; then
    echo "Checking GitHub for ABL updates..."
    
    # Try fetching the latest release tag from the GitHub API
    LATEST_TAG=""
    if LATEST_RELEASE_JSON=$(curl -sL --fail --max-time 10 "https://api.github.com/repos/ROCKNIX/abl/releases/latest" 2>/dev/null); then
        LATEST_TAG=$(echo "$LATEST_RELEASE_JSON" | grep -m1 '"tag_name":' | cut -d'"' -f4 || true)
    fi

    # Fallback: Parse redirection from the standard GitHub URL
    if [ -z "$LATEST_TAG" ]; then
        LATEST_TAG=$(curl -sL --fail --max-time 10 -o /dev/null -w "%{url_effective}" "https://github.com/ROCKNIX/abl/releases/latest" 2>/dev/null | sed 's|.*/tag/||' || true)
    fi

    # Validate tag format (must look like a standard version tag)
    if [[ ! "$LATEST_TAG" =~ ^v[0-9] ]]; then
        LATEST_TAG=""
    fi

    if [ -n "$LATEST_TAG" ]; then
        # Determine local version
        LOCAL_VERSION=""
        if [ -f "${ABL_DIR}/version" ]; then
            LOCAL_VERSION=$(cat "${ABL_DIR}/version" | xargs)
        fi

        # If files don't exist, or local version doesn't match the online release
        if [ ! -f "$ELF" ] || [ ! -f "$SHA256SUM" ] || [ "$LATEST_TAG" != "$LOCAL_VERSION" ]; then
            echo "A newer ABL bootloader ($LATEST_TAG) is available online!"
            
            proceed_download=0
            if [ "$NON_INTERACTIVE" -eq 1 ]; then
                proceed_download=1
            else
                read -p "Do you want to download and flash the new ABL update? (y/N): " -n 1 -r
                echo
                if [[ $REPLY =~ ^[Yy]$ ]]; then
                    proceed_download=1
                fi
            fi

            if [ "$proceed_download" -eq 1 ]; then
                echo "Downloading ABL release ${LATEST_TAG}..."
                
                TMP_DIR=$(mktemp -d)
                TAR_TMP="${TMP_DIR}/rocknix-abl.tar.gz"
                TAR_URL="https://github.com/ROCKNIX/abl/releases/download/${LATEST_TAG}/rocknix-abl-${LATEST_TAG}.tar.gz"

                if ! curl -sL --fail -o "$TAR_TMP" "$TAR_URL"; then
                    echo "Error: Failed to download $TAR_URL. Aborting update."
                    rm -rf "$TMP_DIR"
                    exit 1
                fi
                
                echo "Extracting archive..."
                if ! tar -xzf "$TAR_TMP" -C "$TMP_DIR"; then
                    echo "Error: Failed to extract tarball. Aborting update."
                    rm -rf "$TMP_DIR"
                    exit 1
                fi

                # Locate the specific device binaries recursively inside the extracted archive
                FOUND_ELF=$(find "$TMP_DIR" -type f -name "abl_signed-${HW_DEVICE}.elf" | head -n 1)
                FOUND_SHA=$(find "$TMP_DIR" -type f -name "abl_signed-${HW_DEVICE}.elf.sha256" | head -n 1)

                if [ -z "$FOUND_ELF" ] || [ -z "$FOUND_SHA" ]; then
                    echo "Error: Could not find ABL files for device ${HW_DEVICE} inside the downloaded archive."
                    rm -rf "$TMP_DIR"
                    exit 1
                fi

                # Verify extracted files match the included SHA256 checksum
                echo "Verifying downloaded files..."
                if ! (cd "$(dirname "$FOUND_ELF")" && sha256sum -c "$(basename "$FOUND_SHA")"); then
                    echo "Error: SHA256 checksum verification failed for the downloaded files! Aborting."
                    rm -rf "$TMP_DIR"
                    exit 1
                fi

                # Copy validated files to their destination
                mv "$FOUND_ELF" "$ELF"
                mv "$FOUND_SHA" "$SHA256SUM"
                echo "$LATEST_TAG" > "${ABL_DIR}/version"
                
                # Cleanup temp directory
                rm -rf "$TMP_DIR"
                echo "Download complete and verified."
            else
                echo "Skipping ABL update download."
                # If local files don't exist and user skips download, we must exit
                if [ ! -f "$ELF" ]; then
                    echo "No local ABL files exist. Exiting."
                    exit 0
                fi
            fi
        else
            echo "The latest ABL ($LATEST_TAG) is already downloaded locally."
        fi
    else
        echo "Warning: Could not reach GitHub or determine the latest version. Proceeding with local files if they exist."
    fi
fi

# ---- Sanity checks ----
if [ ! -f "${ELF}" ]; then
  echo "Error: ABL update binary not found at ${ELF}"
  exit 1
fi

if [ ! -f "${SHA256SUM}" ]; then
  echo "Error: SHA256 checksum file not found at ${SHA256SUM}"
  exit 1
fi

if [ ! -b "${ABL_A}" ] || [ ! -b "${ABL_B}" ]; then
  echo "Error: ABL partitions not found"
  exit 1
fi

# ---- Helper: Get Checksum of Partition ----
# We only read the size of the ELF file from the partition to ignore trailing zeros/padding.
FILE_SIZE=$(stat -c%s "${ELF}")
EXPECTED_HASH=$(awk '{print $1}' "${SHA256SUM}")

get_part_hash() {
    local partition=$1
    # Use head to read exactly $FILE_SIZE bytes from the block device
    head -c "$FILE_SIZE" "$partition" | sha256sum | awk '{print $1}'
}

# ---- Power Check ----
check_power() {
    local power_connected=0
    # Check all power supplies for a 'Mains' or 'USB' source that is 'online'
    for supply in /sys/class/power_supply/*; do
        if [ -f "$supply/online" ] && [ -f "$supply/type" ]; then
            type=$(cat "$supply/type")
            online=$(cat "$supply/online")
            if [[ "$type" == "Mains" || "$type" == "USB" ]] && [ "$online" -eq 1 ]; then
                power_connected=1
                break
            fi
        fi
    done

    if [ "$power_connected" -eq 0 ]; then
        echo "------------------------------------------------------------"
        echo " ERROR: DEVICE IS NOT ON AC POWER "
        echo " To prevent bricking during the ABL flash, please plug in "
        echo " your charger/power cable before attempting to flash. "
        echo "------------------------------------------------------------"
        exit 1
    fi
}

# Run the power check
check_power

# ---- Version Check (Pre-flash) ----
echo "Checking current ABL versions..."
HASH_A=$(get_part_hash "$ABL_A")
HASH_B=$(get_part_hash "$ABL_B")

UP_TO_DATE=true
[[ "$HASH_A" != "$EXPECTED_HASH" ]] && UP_TO_DATE=false
[[ "$HASH_B" != "$EXPECTED_HASH" ]] && UP_TO_DATE=false

if [ "$UP_TO_DATE" = true ]; then
    echo "Both ABL partitions are already up to date."
    if [ "$NON_INTERACTIVE" -eq 1 ]; then
        echo "No changes needed. Exiting."
        exit 0
    fi
    read -p "Do you still wish to re-flash? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "No changes needed. Exiting."
        exit 0
    fi
fi

# ---- Disclaimer & Prompt ----
if [ "$NON_INTERACTIVE" -ne 1 ]; then
    cat << EOF
------------------------------------------------------------
Disclaimer
Flashing a custom ABL carries inherent risk and may result 
in an unbootable device if used incorrectly.

- You are responsible for any damage caused
- Ensure you have recovery options before flashing
- This project is provided as-is, with no warranty

This ABL works with a fresh install of v43 or later only.

Created by the ROCKNIX Team for the emulation community.
------------------------------------------------------------
EOF

    echo
    read -p "Do you wish to proceed? (Type Y to continue): " -n 1 -r
    echo # Move to a new line
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Update aborted by user."
        exit 1
    fi
fi

# ---- Check SHA256 ----
echo "Verifying integrity of ABL binary..."
if ! (cd "$(dirname "${ELF}")" && sha256sum -c "$(basename "${SHA256SUM}")"); then
  echo "Error: SHA256 checksum verification failed! Writing aborted."
  exit 1
fi
echo "Checksum verified successfully."

# ---- Get sector size ----
SS="$(blockdev --getss "${ABL_A}")"
if [ -z "${SS}" ]; then
  echo "Error: failed to get sector size"
  exit 1
fi

# ---- Flash with Progress Bar ----
if [ "$NON_INTERACTIVE" -eq 1 ]; then
    # In non-interactive mode, avoid pv progress spamming the logs
    echo "Flashing ABL_A..."
    dd if="${ELF}" of="${ABL_A}" bs="${SS}" conv=fsync,notrunc status=none
    echo "Flashing ABL_B..."
    dd if="${ELF}" of="${ABL_B}" bs="${SS}" conv=fsync,notrunc status=none
else
    echo "Flashing ABL_A..."
    pv -s "$FILE_SIZE" "${ELF}" | dd of="${ABL_A}" bs="${SS}" conv=fsync,notrunc status=none

    echo "Flashing ABL_B..."
    pv -s "$FILE_SIZE" "${ELF}" | dd of="${ABL_B}" bs="${SS}" conv=fsync,notrunc status=none
fi

sync

# ---- Verification (Post-flash) ----
echo "Verifying partitions..."
NEW_HASH_A=$(get_part_hash "$ABL_A")
NEW_HASH_B=$(get_part_hash "$ABL_B")

SUCCESS=true
if [ "$NEW_HASH_A" != "$EXPECTED_HASH" ]; then
    echo "CRITICAL ERROR: ABL_A verification failed!"
    SUCCESS=false
fi
if [ "$NEW_HASH_B" != "$EXPECTED_HASH" ]; then
    echo "CRITICAL ERROR: ABL_B verification failed!"
    SUCCESS=false
fi

if [ "$SUCCESS" = true ]; then
    echo "ABL update completed and verified successfully."
    echo "--- REBOOT device to take effect ---"
else
    echo "Update failed verification. DO NOT REBOOT until you have investigated."
    exit 1
fi
