#!/usr/bin/env python3
"""
Retroid Pocket Mini Fan Service Daemon
Written for Batocera - @lbrpdx

In order to configure your own temperature/fan mapping
edit a file /userdata/system/configs/fan.conf with:

# temperatures are in Celsius
# fan_speed are from 0-100 percent of max speed
# syntax is: temp_threashold=fan_speed
# default is:
# 20=0
# 30=20
# 40=30
# 50=40
# 60=60
# 70=80
# 80=100

"""
import os
import time
import sys
import glob
import subprocess
from threading import Thread

DEBUG = 0
CHECK_INTERVAL = 10 # seconds between two temperature checks

config_file='/userdata/system/configs/fan.conf'

# Read fan % speed from the config file
def get_fanspeed(tempval, configlist):
    for curconfig in configlist:
        curpair = curconfig.split("=")
        tempcfg = float(curpair[0])
        fancfg = int(float(curpair[1]))
        if tempval >= tempcfg:
            return fancfg
    return 0

# Load the config file to memory
def load_config(fname):
    newconfig = []
    try:
        with open(fname, "r") as fp:
            for curline in fp:
                if not curline:
                    continue
                tmpline = curline.strip()
                if not tmpline:
                    continue
                if tmpline[0] == "#":
                    continue
                tmppair = tmpline.split("=")
                if len(tmppair) != 2:
                    continue
                tempval = 0
                fanval = 0
                try:
                    tempval = float(tmppair[0])
                    if tempval < 0 or tempval > 100:
                        continue
                except:
                    continue
                try:
                    fanval = int(float(tmppair[1]))
                    if fanval < 0 or fanval > 100:
                        continue
                except:
                    continue
                newconfig.append("{:5.1f}={}".format(tempval, fanval))
        if len(newconfig) > 0:
            newconfig.sort(reverse=True)
    except:
        return []
    return newconfig

def get_cpu_temp():
    try:
        out = subprocess.check_output(
            ["batocera-temp --cpu"],
            text=True,
            stderr=subprocess.DEVNULL
        ).strip()
        return int(out)
    except Exception:
        return 50 # Fallback safety temperature

# Check the current temperature and adjust fan speed
def temp_check():
    fanconfig = ["80=100", "70=80", "60=60", "50=40", "40=30", "30=20", "20=0"] # Default values
    tmpconfig = load_config(config_file)
    if len(tmpconfig) > 0:
        fanconfig = tmpconfig
    prevblock = -1
    
    try:
        fan_find = glob.glob("/sys/class/hwmon/hwmon*/pwm1")[0] 
        # Attempt to set pwm1_enable to 1 (manual mode) so speed writes work
        enable_path = fan_find + "_enable"
        if os.path.exists(enable_path):
            with open(enable_path, "w") as enable_file:
                enable_file.write("1")
    except IndexError:
        print("Error: no fan control found.")
        sys.exit(1)

    while True:
        val = get_cpu_temp()
        block = get_fanspeed(val, fanconfig)
        if block < prevblock:
            time.sleep(CHECK_INTERVAL)
        prevblock = block
        try:
            num = int(block*2.55)
            if DEBUG:
                print(f"Set fan speed {block}% ({num}) for temp {val}C ")
            with open(fan_find, "w") as fan_file:
                fan_file.write("%i"%num)
        except IOError:
            pass
        time.sleep(CHECK_INTERVAL)

# argument: start, stop, or no argument = show temp
if len(sys.argv)>1:
    if str(sys.argv[1]) == "start":
        try:
            t = Thread(target=temp_check, daemon=True)
            t.start()
            # Keep main thread alive while background thread runs
            while True:
                time.sleep(1)
        except KeyboardInterrupt:
            print("Daemon stopped manually.")
        except Exception as e:
            print(f"Could not launch daemon: {e}")
            sys.exit(1)
    elif str(sys.argv[1]) == "stop":
        try:
            # Force fan stop and restore auto control if supported
            fan_find = glob.glob("/sys/class/hwmon/hwmon*/pwm1")[0] 
            with open(fan_find, "w") as fan_file:
                fan_file.write("0")
            enable_path = fan_find + "_enable"
            if os.path.exists(enable_path):
                with open(enable_path, "w") as enable_file:
                    enable_file.write("2") # Back to auto mode
        except Exception as e:
            print(f"Could not stop fan: {e}")
else:
    val = get_cpu_temp()
    print(f"Temp: {val}C")
