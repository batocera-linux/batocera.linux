#!/bin/bash

SYS_CFG="/boot/EFI/batocera/syslinux.cfg"

usage() {
    echo "Usage: $0 {off|on|status|info}" >&2
    exit 1
}

remount_boot_write() {
    echo "Remounting /boot read-write..."
    mount -o remount,rw /boot || {
        echo "ERROR: failed to remount /boot read-write" >&2
        exit 1
    }
}

remount_boot_read() {
    echo "Remounting /boot read-only..."
    mount -o remount,ro /boot || {
        echo "ERROR: failed to remount /boot read-only" >&2
        return 1
    }
}

backup_config() {
    BACKUP="${SYS_CFG}.bak.$(date +%Y%m%d-%H%M%S)"
    echo "Creating backup: $BACKUP"

    cp -a "$SYS_CFG" "$BACKUP" || {
        echo "ERROR: failed to create backup" >&2
        remount_boot_read
        exit 1
    }
}

get_batocera_block() {
    sed -n '/^LABEL[[:space:]]\+batocera$/,/^LABEL[[:space:]]/p' "$SYS_CFG"
}

has_mitigations_off() {
    get_batocera_block | grep -qE '^[[:space:]]*APPEND[[:space:]].*(^|[[:space:]])mitigations=off([[:space:]]|$)'
}

show_append_line() {
    get_batocera_block | grep -E '^[[:space:]]*APPEND[[:space:]]'
}

ACTION="$1"

case "$ACTION" in
    off|on|status|info)
        ;;
    *)
        usage
        ;;
esac

if [ ! -f "$SYS_CFG" ]; then
    echo "ERROR: $SYS_CFG not found" >&2
    exit 1
fi

case "$ACTION" in
    status)
        if has_mitigations_off; then
            echo "0"
        else
            echo "1"
        fi
        exit 0
        ;;

    info)
        if has_mitigations_off; then
            echo "Mitigations are OFF."
        else
            echo "Mitigations are ON(default)."
        fi

        echo "Current default batocera APPEND line:"
        show_append_line
        exit 0
        ;;

    off)
        if has_mitigations_off; then
            echo "Mitigations are already OFF."
            show_append_line
            exit 0
        fi

        remount_boot_write
        backup_config

        echo "Setting mitigations OFF..."

        sed -i '/^LABEL[[:space:]]\+batocera$/,/^LABEL[[:space:]]/ {
            /^[[:space:]]*APPEND[[:space:]]/ {
                /(^\|[[:space:]])mitigations=off\([[:space:]]\|$\)/! s/[[:space:]]*$/ mitigations=off/
            }
        }' "$SYS_CFG" || {
            echo "ERROR: failed to apply change" >&2
            remount_boot_read
            exit 1
        }

        remount_boot_read || exit 1

        echo "Done. Default batocera APPEND line:"
        show_append_line
        ;;

    on)
        if ! has_mitigations_off; then
            echo "Mitigations are already ON(default)."
            show_append_line
            exit 0
        fi

        remount_boot_write
        backup_config

        echo "Removing mitigations=off..."

        sed -i '/^LABEL[[:space:]]\+batocera$/,/^LABEL[[:space:]]/ {
            /^[[:space:]]*APPEND[[:space:]]/ {
                s/[[:space:]]mitigations=off\([[:space:]]\|$\)/\1/g
                s/[[:space:]]*$//
            }
        }' "$SYS_CFG" || {
            echo "ERROR: failed to apply change" >&2
            remount_boot_read
            exit 1
        }

        remount_boot_read || exit 1

        echo "Done. Default batocera APPEND line:"
        show_append_line
        ;;
esac

exit 0
