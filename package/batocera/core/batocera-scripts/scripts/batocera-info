#!/bin/bash

### full version (not on login, otherwise you can't log when OpenGL/Vulkan are out of order)
if test "$1" = "--full"; then
	FULL_DISPLAY=1
else
	FULL_DISPLAY=0
fi
###

if test -z "${DISPLAY}"; then
    export DISPLAY=$(getLocalXDisplay)
fi

# ---------------------------------------------------------------------------
# CPU: online CPUs only
# ---------------------------------------------------------------------------
getCpu() {
    test -e "${1}/cpufreq/scaling_max_freq" || return 0
    if test -e "${1}/online"; then
        OL=$(cat "${1}/online")
        test "${OL}" = 1 || return 0
    fi
    cat "${1}/cpufreq/scaling_max_freq"
}

# ---------------------------------------------------------------------------
# Battery capacity
# ---------------------------------------------------------------------------
BATTERY_DIR=$(ls -d /sys/class/power_supply/*{BAT,bat}* 2>/dev/null | head -1)
BATT=$(awk -F= '/^POWER_SUPPLY_CAPACITY=/{print $2; exit}' "${BATTERY_DIR}/uevent" 2>/dev/null)

if [ -z "${BATT}" ]; then
    BATTERY_DIR=$(ls -d /sys/class/power_supply/*{FUEL,fuel}* 2>/dev/null | head -1)
    NOW=$(awk -F= '/^POWER_SUPPLY_CHARGE_NOW=/{print $2; exit}' "${BATTERY_DIR}/uevent" 2>/dev/null)
    MAX=$(awk -F= '/^POWER_SUPPLY_CHARGE_FULL=/{print $2; exit}' "${BATTERY_DIR}/uevent" 2>/dev/null)
    if [ -n "$NOW" ] && [ -n "$MAX" ] && [ "$MAX" -ne 0 ]; then
        BATT=$(( (100 * NOW + MAX / 2) / MAX ))   # rounded integer division
    fi
fi

# ---------------------------------------------------------------------------
# Battery time-remaining
# ---------------------------------------------------------------------------
if [ -n "${BATTERY_DIR}" ]; then
    BATTREMAINING=""
    TIME_TO_EMPTY=$(awk -F= '/^POWER_SUPPLY_TIME_TO_EMPTY_NOW=/{print $2; exit}' \
        "${BATTERY_DIR}/uevent" 2>/dev/null)

    if [ -n "${TIME_TO_EMPTY}" ] && [ "${TIME_TO_EMPTY}" -gt 0 ]; then
        BATTREMAINING_HOURS=$(( TIME_TO_EMPTY / 3600 ))
        BATTREMAINING_MINS=$(( TIME_TO_EMPTY % 3600 / 60 ))
        printf -v BATTREMAINING_MINS "%02d" "${BATTREMAINING_MINS}"
        BATTREMAINING=" (${BATTREMAINING_HOURS}:${BATTREMAINING_MINS})"
    else
        BATTREMAINING_CURRENT=$(cat "${BATTERY_DIR}/current_now" 2>/dev/null)
        BATTREMAINING_CHARGE=$(cat "${BATTERY_DIR}/charge_now" 2>/dev/null)
        if [ -n "${BATTREMAINING_CURRENT}" ] && [ -n "${BATTREMAINING_CHARGE}" ] \
           && [ "${BATTREMAINING_CURRENT}" -gt 0 ]; then
            TIME_TO_EMPTY=$(( BATTREMAINING_CHARGE * 3600 / BATTREMAINING_CURRENT ))
            BATTREMAINING_HOURS=$(( TIME_TO_EMPTY / 3600 ))
            BATTREMAINING_MINS=$(( TIME_TO_EMPTY % 3600 / 60 ))
            printf -v BATTREMAINING_MINS "%02d" "${BATTREMAINING_MINS}"
            BATTREMAINING=" (${BATTREMAINING_HOURS}:${BATTREMAINING_MINS})"
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Short mode (for OSD)
# ---------------------------------------------------------------------------
if test "$1" = "--short"; then
    DT=$(date +%H:%M)
    if test -n "${BATT}"; then
        echo "Battery: ${BATT}%${BATTREMAINING} - ${DT}"
    else
        echo "${DT}"
    fi
    exit 0
fi

# ---------------------------------------------------------------------------
# Board / system basics
# ---------------------------------------------------------------------------
V_BOARD=$(cat /boot/boot/batocera.board 2>/dev/null)
V_SYSTEM=$(uname -rs)
V_ARCH=$(uname -m)

V_BOARD_MODEL=$(batocera-model 2>/dev/null)
if test -n "${V_BOARD_MODEL}"; then
    echo "Model: ${V_BOARD_MODEL}"
fi

echo "System: ${V_SYSTEM}"
echo "Architecture: ${V_ARCH}"
if [ "$V_BOARD" != "$V_ARCH" ]; then
    echo "Board: ${V_BOARD}"
fi

# RPi revision
if echo "${V_BOARD}" | grep -qE "^rpi[0-9]$"; then
    REVISION=$(awk -F': ' '/^Revision/{print $2; exit}' /proc/cpuinfo 2>/dev/null)
    test -n "${REVISION}" && echo "Revision: ${REVISION}"
fi

# ---------------------------------------------------------------------------
# CPU model
# ---------------------------------------------------------------------------
V_CPUMODEL1=$(awk -F': ' '/^(model name|Model name|cpu model)/{print $2; exit}' \
    /proc/cpuinfo 2>/dev/null)
[[ -z "${V_CPUMODEL1}" ]] || echo "CPU Model: ${V_CPUMODEL1}"

V_CPUMAXNB=$(grep -c '^processor' /proc/cpuinfo 2>/dev/null)

# Count unique physical cores via (physical id, core id) pairs from /proc/cpuinfo
V_CPUNB=$(awk '/^physical id/{pkg=$NF} /^core id/{print pkg, $NF}' \
    /proc/cpuinfo 2>/dev/null | sort -u | wc -l)

# big.LITTLE — e.g. both clusters report 0-3, so we use (cluster_id, core_id).
if [ "${V_CPUNB}" -eq 0 ] 2>/dev/null; then
    V_CPUNB=$(for cpu in /sys/devices/system/cpu/cpu[0-9]*; do
        cluster=$(cat "${cpu}/topology/physical_package_id" 2>/dev/null || \
                  cat "${cpu}/topology/cluster_id" 2>/dev/null || echo 0)
        core=$(cat "${cpu}/topology/core_id" 2>/dev/null || echo "")
        [ -n "$core" ] && echo "${cluster}:${core}"
    done | sort -u | wc -l)
fi

# Last resort: treat logical == physical
if [ "${V_CPUNB}" -eq 0 ] 2>/dev/null; then
    V_CPUNB="${V_CPUMAXNB}"
fi

if test "${V_CPUMAXNB}" = "${V_CPUNB}"; then
    echo "CPU Cores: ${V_CPUNB}"
else
    echo "CPU Cores: ${V_CPUNB} / CPU Threads: ${V_CPUMAXNB}"
fi


declare -A RAW_FREQ_COUNT
declare -A RAW_FREQ_CAP

for CPU in /sys/devices/system/cpu/cpu[0-9]*; do
    F=$(getCpu "${CPU}")
    [ -z "$F" ] && continue
    CAP=$(cat "${CPU}/cpu_capacity" 2>/dev/null || echo "")
    RAW_FREQ_COUNT["$F"]=$(( ${RAW_FREQ_COUNT["$F"]:-0} + 1 ))
    [ -n "$CAP" ] && RAW_FREQ_CAP["$F"]="$CAP"
done

# Check if cpu_capacity has distinct values (ARM big.LITTLE)
declare -A CAP_SEEN
for F in "${!RAW_FREQ_CAP[@]}"; do CAP_SEEN["${RAW_FREQ_CAP[$F]}"]=1; done
NUM_CAP_TYPES=${#CAP_SEEN[@]}

declare -A CLUSTER_FREQ
declare -A CLUSTER_COUNT

if [ "${NUM_CAP_TYPES}" -gt 1 ]; then
    for F in "${!RAW_FREQ_COUNT[@]}"; do
        CAP="${RAW_FREQ_CAP[$F]}"
        CLUSTER_COUNT["$CAP"]=$(( ${CLUSTER_COUNT["$CAP"]:-0} + ${RAW_FREQ_COUNT[$F]} ))
        PREV=${CLUSTER_FREQ["$CAP"]:-0}
        [ "$F" -gt "$PREV" ] && CLUSTER_FREQ["$CAP"]="$F"
    done
else
    # x86 / generic: merge freq buckets within 15% of the cluster base freq
    SORTED_FREQS=$(printf '%s\n' "${!RAW_FREQ_COUNT[@]}" | sort -n)
    CLUSTER_BASE=""
    CLUSTER_MAX=""
    CLUSTER_SZ=0
    CIDX=0

    while IFS= read -r F; do
        if [ -z "$CLUSTER_BASE" ]; then
            CLUSTER_BASE="$F"; CLUSTER_MAX="$F"
            CLUSTER_SZ="${RAW_FREQ_COUNT[$F]}"; CIDX=1
        else
            THRESHOLD=$(( CLUSTER_BASE + CLUSTER_BASE * 15 / 100 ))
            if [ "$F" -le "$THRESHOLD" ]; then
                CLUSTER_SZ=$(( CLUSTER_SZ + ${RAW_FREQ_COUNT[$F]} ))
                [ "$F" -gt "$CLUSTER_MAX" ] && CLUSTER_MAX="$F"
            else
                CLUSTER_FREQ["c${CIDX}"]="$CLUSTER_MAX"
                CLUSTER_COUNT["c${CIDX}"]="$CLUSTER_SZ"
                CIDX=$(( CIDX + 1 ))
                CLUSTER_BASE="$F"; CLUSTER_MAX="$F"
                CLUSTER_SZ="${RAW_FREQ_COUNT[$F]}"
            fi
        fi
    done <<< "$SORTED_FREQS"
    [ -n "$CLUSTER_BASE" ] && CLUSTER_FREQ["c${CIDX}"]="$CLUSTER_MAX" && CLUSTER_COUNT["c${CIDX}"]="$CLUSTER_SZ"
fi

NUM_CLUSTERS=${#CLUSTER_COUNT[@]}

if [ "${NUM_CLUSTERS}" -gt 1 ]; then
    CLUSTER_IDX=1
    for CAP in $(for k in "${!CLUSTER_FREQ[@]}"; do
                     echo "${CLUSTER_FREQ[$k]} $k"
                 done | sort -n | awk '{print $2}'); do
        FREQ_MHZ=$(( CLUSTER_FREQ[$CAP] / 1000 ))
        COUNT=${CLUSTER_COUNT[$CAP]}
        echo "CPU Cluster ${CLUSTER_IDX}: ${COUNT} core(s) @ max ${FREQ_MHZ} MHz"
        CLUSTER_IDX=$(( CLUSTER_IDX + 1 ))
    done
elif [ "${NUM_CLUSTERS}" -eq 1 ]; then
    ONLY_CAP="${!CLUSTER_FREQ[@]}"
    V_CPUMAXFREQ=$(( CLUSTER_FREQ[$ONLY_CAP] / 1000 ))
    echo "CPU Max Frequency: ${V_CPUMAXFREQ} MHz"
fi


# ---------------------------------------------------------------------------
# CPU feature flags
# ---------------------------------------------------------------------------
declare -a check_cpu_features=("avx2" "sse4_1" "neon" "asimd" "sve" "sve2" "vfpv4")
declare -a cpu_features=()
CPU_FLAGS_LINE=$(grep -m1 -E '^(flags|Features)\s*:' /proc/cpuinfo 2>/dev/null | \
                 sed 's/^[^:]*: //')
for feature in "${check_cpu_features[@]}"; do
    if echo " ${CPU_FLAGS_LINE} " | grep -qw "${feature}"; then
        cpu_features+=("${feature}")
    fi
done

if [ "${#cpu_features[@]}" -gt 0 ]; then
    echo "CPU Features: ${cpu_features[*]}"
fi

# ---------------------------------------------------------------------------
# TDP (Ryzen Mobile)
# ---------------------------------------------------------------------------
CPU_TDP=$(/usr/bin/batocera-settings-get system.cpu.tdp 2>/dev/null)
if [ -n "$CPU_TDP" ]; then
    MAX_TDP=$(/usr/bin/ryzenadj -i 2>/dev/null | \
              awk '/PPT LIMIT FAST/ {printf "%.0f\n", $6}')
    [ -n "$MAX_TDP" ] && echo "Ryzen Mobile TDP: ${MAX_TDP}W"
fi

# ---------------------------------------------------------------------------
# Temperature
# ---------------------------------------------------------------------------
get_temperature() {
    local best=""
    for zone in /sys/devices/virtual/thermal/thermal_zone*; do
        local type
        type=$(cat "${zone}/type" 2>/dev/null)
        # Prefer known CPU zone types
        case "${type}" in
            cpu-thermal|x86_pkg_temp|cpu_thermal|arm-thermal|soc-thermal)
                local t
                t=$(cat "${zone}/temp" 2>/dev/null)
                if [ -n "$t" ] && { [ -z "$best" ] || [ "$t" -gt "$best" ]; }; then
                    best="$t"
                fi
                ;;
        esac
    done

    # Fall back: hwmon temp*_input, excluding "in" (voltage) sensors
    if [ -z "$best" ]; then
        best=$(cat /sys/class/hwmon/hwmon*/temp*_input 2>/dev/null | \
               sort -rn | head -1)
    fi

    # Still nothing: global thermal_zone max
    if [ -z "$best" ]; then
        best=$(cat /sys/devices/virtual/thermal/thermal_zone*/temp 2>/dev/null | \
               sort -rn | head -1)
    fi

    # Trim trailing 3 digits (millidegree → degree)
    echo "${best}" | sed -e 's/[0-9][0-9][0-9]$//'
}

TEMPE=$(get_temperature)
if test -n "${TEMPE}"; then
    echo "Temperature: ${TEMPE}°C"
fi

# ---------------------------------------------------------------------------
# Memory
# ---------------------------------------------------------------------------
MEM_TOTAL_KB=$(grep -E "^MemTotal:" /proc/meminfo | awk '{print $2}')
MEM_AVAILABLE_KB=$(grep -E "^MemAvailable:" /proc/meminfo | awk '{print $2}')
MEM_TOTAL_MB=$(( MEM_TOTAL_KB / 1024 ))
MEM_AVAILABLE_MB=$(( MEM_AVAILABLE_KB / 1024 ))
echo "Available Memory: ${MEM_AVAILABLE_MB}/${MEM_TOTAL_MB} MB"

# ---------------------------------------------------------------------------
# Display server / compositor / outputs
# ---------------------------------------------------------------------------
DISPLAY_SERVER=$(batocera-resolution getDisplayMode 2>/dev/null)
[ -n "$DISPLAY_SERVER" ] && echo "Display Server: ${DISPLAY_SERVER}"

DISPLAY_COMPOSITOR=$(batocera-resolution getDisplayComp 2>/dev/null)
[ -n "$DISPLAY_COMPOSITOR" ] && echo "Display Compositor: ${DISPLAY_COMPOSITOR}"

OUTPUTS=$(batocera-resolution listOutputs 2>/dev/null)
set -- ${OUTPUTS}
NUM_OUTPUTS=$#

get_displayrate() {
    local mode="$1"
    if [ -n "$WAYLAND_DISPLAY" ]; then
        echo "${mode}" | awk -F'[x.]' '{printf "%.3f", $3 / 1000}'
    elif test -f /var/run/drmMode; then
        echo "${mode}" | awk -F'\\.' '{print $4}'
    else
        echo "${mode}" | awk -F'\\.' '{print $2"."$3}'
    fi
}

if [ "${NUM_OUTPUTS}" -le 1 ]; then
    echo "Display Output: ${OUTPUTS}"
    DISPLAYRES=$(batocera-resolution currentResolution 2>/dev/null)
    DISPLAYRATE=$(get_displayrate "$(batocera-resolution currentMode 2>/dev/null)")
    echo "Display Resolution: ${DISPLAYRES}"
    echo "Display Refresh Rate: ${DISPLAYRATE}Hz"
else
    i=1
    for output in ${OUTPUTS}; do
        CURRENT_MODE=$(batocera-resolution --screen "${output}" currentMode 2>/dev/null)
        # Skip disabled/disconnected outputs
        case "${CURRENT_MODE}" in
            "unknown.0"|"unknown"|"") continue ;;
        esac
        DISPLAYRES=$(batocera-resolution --screen "${output}" currentResolution 2>/dev/null)
        DISPLAYRATE=$(get_displayrate "${CURRENT_MODE}")
        echo "Display Output ${i}: ${output}"
        echo "Display Resolution ${i}: ${DISPLAYRES}"
        echo "Display Refresh Rate ${i}: ${DISPLAYRATE}Hz"
        i=$(( i + 1 ))
    done
fi

# ---------------------------------------------------------------------------
# OpenGL / Vulkan  (--full only)
# ---------------------------------------------------------------------------
if [[ "${FULL_DISPLAY}" != 0 ]]; then
    # OpenGL – x86/x86_64 only via glxinfo
    if test "${V_BOARD}" = "x86" -o "${V_BOARD}" = "x86_64"; then
        V_OPENGLVERSION=$(DISPLAY=$(getLocalXDisplay) glxinfo 2>/dev/null | \
            awk '/^OpenGL core profile version string:/{sub(/^OpenGL core profile version string:[ ]*/,""); print; exit}')
        if test -z "${V_OPENGLVERSION}"; then
            V_OPENGLVERSION=$(DISPLAY=$(getLocalXDisplay) glxinfo 2>/dev/null | \
                awk '/^OpenGL version string:/{sub(/^OpenGL version string:[ ]*/,""); print; exit}')
        fi
        echo "OpenGL Driver Version: ${V_OPENGLVERSION}"
    fi

    # Vulkan
    if [ "$(batocera-vulkan hasVulkan 2>/dev/null)" = "true" ]; then
        if [ "$(batocera-vulkan hasDiscrete 2>/dev/null)" = "true" ]; then
            echo "Vulkan Driver Name: $(batocera-vulkan discreteName 2>/dev/null | tr -d '\n')"
            discreteIndex=$(batocera-vulkan discreteIndex 2>/dev/null)
            apiVersion=$(vulkaninfo 2>/dev/null | \
                awk "/GPU${discreteIndex}/{found=1} found && /apiVersion/{print \$3; exit}")
            echo "Vulkan Driver Version: $apiVersion"
        else
            echo "Vulkan Driver Name: $(batocera-vulkan listDevices 2>/dev/null | tr -d '\n')"
            apiVersion=$(vulkaninfo 2>/dev/null | \
                awk '/GPU0/{found=1} found && /apiVersion/{print $3; exit}')
            echo "Vulkan Driver Version: $apiVersion"
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Storage / userdata
# ---------------------------------------------------------------------------
INTERNALDEVICE=$(batocera-part "share" 2>/dev/null)
INTERNALDEVICETYPE=$(blkid "${INTERNALDEVICE}" 2>/dev/null | \
    sed -nE 's/.*\bTYPE="([^"]*)".*/\1/p')
echo "Data Partition Format: ${INTERNALDEVICETYPE}"
echo "Data Partition Available Space: $(df -h "${INTERNALDEVICE}" 2>/dev/null | \
    awk 'NR==2 {print $4}')"

# ---------------------------------------------------------------------------
# Network – IP address (IPv4 then IPv6 fallback)
# ---------------------------------------------------------------------------
PREFSRC=$(ip -j route get 1.1.1.1 2>/dev/null | jq -r '.[].prefsrc // empty')
if [ -z "$PREFSRC" ]; then
    PREFSRC=$(ip -j route get 1:: 2>/dev/null | jq -r '.[].prefsrc // empty')
fi
[ -n "$PREFSRC" ] && echo "Network IP Address: $PREFSRC"

# ---------------------------------------------------------------------------
# MAC address (--full only)
# ---------------------------------------------------------------------------
if [[ "${FULL_DISPLAY}" != 0 ]]; then
    IFACE=$(ip -j route get 1.1.1.1 2>/dev/null | jq -r '.[].dev // empty')
    if [ -n "${IFACE}" ]; then
        MACADDR=$(cat "/sys/class/net/${IFACE}/address" 2>/dev/null | tr ':' '-')
        [ -n "${MACADDR}" ] && echo "Corresponding MAC Address: ${MACADDR}"
    fi
fi

# ---------------------------------------------------------------------------
# Boot / UEFI / Secure Boot (--full only)
# ---------------------------------------------------------------------------
if [[ "${FULL_DISPLAY}" != 0 ]]; then
    if [ -d /sys/firmware/efi ]; then
        echo "UEFI Boot: Yes"
        if [ -x /usr/bin/mokutil ]; then
            echo "Secure Boot: $(mokutil --sb-state 2>&1 | \
                sed 's/^SecureBoot validation is//' | paste -sd ';')"
        fi
    else
        echo "UEFI Boot: No"
    fi
fi

# ---------------------------------------------------------------------------
# Battery level
# ---------------------------------------------------------------------------
if test -n "${BATT}"; then
    echo "Battery: ${BATT}%${BATTREMAINING}"
fi

# ---------------------------------------------------------------------------
# Battery health - iterate all BAT* devices, handle energy_full and charge_full
# ---------------------------------------------------------------------------
for BAT_PATH in /sys/class/power_supply/BAT* /sys/class/power_supply/bat*; do
    [ -e "${BAT_PATH}" ] || continue
    BAT_NAME=$(basename "${BAT_PATH}")

    # Prefer energy (uWh), fall back to charge (uAh) - ratio is the same either way
    if [ -e "${BAT_PATH}/energy_full_design" ] && [ -e "${BAT_PATH}/energy_full" ]; then
        FULL_DESIGN=$(cat "${BAT_PATH}/energy_full_design" 2>/dev/null)
        FULL_NOW=$(cat "${BAT_PATH}/energy_full" 2>/dev/null)
    elif [ -e "${BAT_PATH}/charge_full_design" ] && [ -e "${BAT_PATH}/charge_full" ]; then
        FULL_DESIGN=$(cat "${BAT_PATH}/charge_full_design" 2>/dev/null)
        FULL_NOW=$(cat "${BAT_PATH}/charge_full" 2>/dev/null)
    else
        continue
    fi

    if [ -n "${FULL_DESIGN}" ] && [ "${FULL_DESIGN}" -gt 0 ] 2>/dev/null; then
        battery_health=$(awk -v cur="${FULL_NOW}" -v des="${FULL_DESIGN}" \
            'BEGIN { h = cur/des*100; if(h>100) h=100; printf "%.0f", h }')
        BAT_COUNT=$(ls -d /sys/class/power_supply/{BAT,bat}* 2>/dev/null | wc -l)
        if [ "${BAT_COUNT}" -gt 1 ]; then
            echo "Battery Health (${BAT_NAME}): ${battery_health}%"
        else
            echo "Battery Health: ${battery_health}%"
        fi
    fi
done

# ---------------------------------------------------------------------------
# PAD / controller battery levels
# ---------------------------------------------------------------------------
for PADBAT in /sys/class/power_supply/*/device/uevent; do
    if test -e "${PADBAT}"; then
        # HID devices only
        PADNAME=$(sed -nE 's/^HID_NAME=(.*)/\1/p' "${PADBAT}")
        if test -n "${PADNAME}"; then
            # Remove PID if it exists in the name
            PADNAME=$(echo "${PADNAME}" | sed -E 's/ PID:[0-9]+//')
            # parent of parent / uevent
            BATTUEVENT=$(dirname "${PADBAT}")
            BATTUEVENT=$(dirname "${BATTUEVENT}")/uevent
            BATT="$(batocera-padsinfo "${BATTUEVENT}" 2>/dev/null)"
            echo "${PADNAME}: ${BATT}%"
        fi
    fi
done
