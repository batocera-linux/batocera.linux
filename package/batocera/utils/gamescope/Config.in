config BR2_PACKAGE_GAMESCOPE
        bool "gamescope"
        depends on BR2_x86_64
        depends on BR2_TOOLCHAIN_HAS_THREADS # wlroots
        depends on BR2_PACKAGE_HAS_LIBEGL # wlroots
        depends on BR2_PACKAGE_HAS_LIBGLES # wlroots
        depends on BR2_PACKAGE_HAS_UDEV # wlroots

        select BR2_PACKAGE_SEATD
        select BR2_PACKAGE_SEATD_DAEMON
        select BR2_PACKAGE_SDL2
        select BR2_PACKAGE_LUAJIT
        select BR2_PACKAGE_LIBINPUT
        select BR2_PACKAGE_WAYLAND
        select BR2_PACKAGE_WAYLAND_PROTOCOLS
        select BR2_PACKAGE_LIBXCB
        select BR2_PACKAGE_LIBXKBCOMMON
        select BR2_PACKAGE_LIBDRM
        select BR2_PACKAGE_LIBX11
        select BR2_PACKAGE_LIBXDAMAGE
        select BR2_PACKAGE_LIBXEXT
        select BR2_PACKAGE_LIBXFIXES
        select BR2_PACKAGE_LIBXRENDER
        select BR2_PACKAGE_LIBXRES
        select BR2_PACKAGE_LIBXTST
        select BR2_PACKAGE_LIBDECOR
        select BR2_PACKAGE_XWAYLAND
        select BR2_PACKAGE_LIBAVIF
        select BR2_PACKAGE_PIPEWIRE

        help
          SteamOS session compositing window manager

          https://github.com/Plagman/gamescope
