config BR2_PACKAGE_MOONLIGHT_QT
	bool "moonlight-qt"
	select BR2_PACKAGE_MOONLIGHT_COMMON
	select BR2_PACKAGE_QT6
	select BR2_PACKAGE_QT6BASE
	select BR2_PACKAGE_QT6BASE_NETWORK
	# host qmlprofiler is needed, which is part of QtNetwork
	select BR2_PACKAGE_HOST_QT6BASE_NETWORK
	select BR2_PACKAGE_QT6SVG
	select BR2_PACKAGE_QT6DECLARATIVE
	select BR2_PACKAGE_QT6DECLARATIVE_QUICK
	select BR2_PACKAGE_QT6DECLARATIVE_QUICK_CONTROLS2
	select BR2_PACKAGE_QT6WAYLAND    if BR2_PACKAGE_WAYLAND
	select BR2_PACKAGE_OPUS
	select BR2_PACKAGE_SDL2
	select BR2_PACKAGE_SDL2_TTF
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_FFMPEG
	select BR2_PACKAGE_FFMPEG_SWSCALE
	help
	  GameStream client for PCs

	  https://github.com/moonlight-stream/moonlight-qt
