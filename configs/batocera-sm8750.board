include batocera-board.common

# Target definition
BR2_aarch64=y
BR2_qualcomm_oryon_1=y
BR2_ARM_FPU_NEON_FP_ARMV8=y
BR2_TOOLCHAIN_BUILDROOT_WCHAR=y
BR2_PACKAGE_BATOCERA_TARGET_SM8750=y
BR2_TARGET_OPTIMIZATION="-pipe -fsigned-char -mcpu=oryon-1"
BR2_TARGET_GENERIC_GETTY_PORT="ttyMSM0"
BR2_TARGET_GENERIC_GETTY_BAUDRATE_115200=y
BR2_TARGET_BATOCERA_IMAGES="qualcomm/sm8750"
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/fsoverlay $(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/qualcomm/sm8750/fsoverlay"
BR2_GLOBAL_PATCH_DIR="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/patches $(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/qualcomm/sm8750/patches"

# Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="7.1.2"
BR2_KERNEL_HEADERS_7_1=y
BR2_LINUX_KERNEL_PATCH="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/qualcomm/sm8750/linux_patches"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/qualcomm/sm8750/linux_sm8750-defconfig.config"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_INTREE_DTS_NAME="qcom/cq8725s-ayn-odin3"

# Filesystem tools
BR2_PACKAGE_HOST_DOSFSTOOLS=y
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_PACKAGE_HOST_MTOOLS=y

# GPU
BR2_PACKAGE_BATOCERA_FREEDRENO_MESA3D=y
BR2_PACKAGE_BATOCERA_WAYLAND_LABWC=y
BR2_PACKAGE_BATOCERA_XWAYLAND=y

# Firmware
BR2_PACKAGE_FIRMWARE_ARMBIAN=y

# Bootloader
BR2_PACKAGE_ROCKNIX_ABL=y
BR2_PACKAGE_HOST_PYTHON_MKBOOTIMG=y

# Batocera Splash Support
BR2_PACKAGE_BATOCERA_SPLASH_MPV=y
BR2_PACKAGE_BATOCERA_KODI21=y
