include batocera-board.common

# Target definition
BR2_aarch64=y
BR2_cortex_a73_a53=y
BR2_ARM_FPU_NEON_FP_ARMV8=y
BR2_PACKAGE_BATOCERA_TARGET_A3GEN2=y
BR2_TARGET_OPTIMIZATION="-pipe -fsigned-char"
BR2_TARGET_GENERIC_GETTY_PORT="ttyS0"
BR2_TARGET_GENERIC_GETTY_BAUDRATE_KEEP=y
BR2_GLOBAL_PATCH_DIR="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/patches $(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/amlogic/patches $(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/amlogic/a3gen2/patches"
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/fsoverlay $(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/amlogic/fsoverlay $(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/amlogic/a3gen2/fsoverlay"

# Linux headers same as kernel, a 5.15 series
# BR2_KERNEL_HEADERS_AS_KERNEL=y
# BR2_PACKAGE_HOST_LINUX_HEADERS_CUSTOM_5_15=y
# Use mainline kernel headers directly. Using vendor headers requires copying amlogic-common-drivers to the source tree,
# but since we can't modify Buildroot core, we can't make linux-headers depend on amlogic-common-drivers to prioritize its extraction.
BR2_KERNEL_HEADERS_5_15=y

# Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_GIT=y
# Branch: khadas-vims-5.15.y, Commit date: Aug 20, 2025 (please update when updating commit ref)
BR2_LINUX_KERNEL_CUSTOM_REPO_URL="https://github.com/khadas/linux.git"
BR2_LINUX_KERNEL_CUSTOM_REPO_VERSION="4e557e233b9da219f48b82bfa313f353386097ec"
BR2_LINUX_KERNEL_PATCH="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/amlogic/a3gen2/linux_patches"
BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/amlogic/a3gen2/linux-amlogic-5.15.y.config"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_BATOCERA_PATH)/board/batocera/amlogic/a3gen2/linux-defconfig-fragment.config"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y
# Branch: khadas-vims-5.15.y, Commit date: Mar 16, 2026 (please update when updating commit ref)
BR2_PACKAGE_AMLOGIC_COMMON_DRIVERS=y
BR2_PACKAGE_AMLOGIC_COMMON_DRIVERS_REPOSITORY="https://github.com/khadas/common_drivers.git"
BR2_PACKAGE_AMLOGIC_COMMON_DRIVERS_VERSION="2eef6f0d16b77777dc33634b5a99dab181fb7152"

# Build the DTB from the kernel sources
BR2_LINUX_KERNEL_DTS_SUPPORT=y
BR2_LINUX_KERNEL_INTREE_DTS_NAME="kvim4 kvim4n"

# System
BR2_PACKAGE_BATOCERA_KODI21=y
BR2_TARGET_ROOTFS_SQUASHFS4_ZSTD=y

# GPU
BR2_PACKAGE_BATOCERA_PANFROST_MESA3D=y
BR2_PACKAGE_BATOCERA_WAYLAND_LABWC=y

# Filesystem tools
BR2_PACKAGE_HOST_DOSFSTOOLS=y
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_PACKAGE_HOST_MTOOLS=y

# Firmware
BR2_PACKAGE_FIRMWARE_KHADAS_VIM4=y

# Bootloader
BR2_PACKAGE_UBOOT_VIM4=y

# choices can be put in _defconfig files only
BR2_PACKAGE_BATOCERA_SPLASH_MPV=y
