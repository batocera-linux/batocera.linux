&i2c9 {
	status = "okay";
	clock-frequency = <400000>;

	/*
	 * Per the Android DTS, the chip at I2C address 0x34 drives the
	 * RIGHT speaker (sound-channel = 1, reset gpio 98) and the chip
	 * at 0x35 drives the LEFT speaker (sound-channel = 0, reset gpio 94).
	 */
	spk_amp_r: speaker@34 {
		compatible = "awinic,aw88166";
		reg = <0x34>;
		#sound-dai-cells = <0>;
		reset-gpios = <&tlmm 98 GPIO_ACTIVE_LOW>;
		awinic,audio-channel = <0>;
		awinic,sync-flag;
		sound-name-prefix = "SpkrRight";
		firmware-name = "qcom/sm8250/ayn/thor/aw883xx_acf.bin";
	};

	spk_amp_l: speaker@35 {
		compatible = "awinic,aw88166";
		reg = <0x35>;
		#sound-dai-cells = <0>;
		reset-gpios = <&tlmm 94 GPIO_ACTIVE_LOW>;
		awinic,audio-channel = <1>;
		awinic,sync-flag;
		sound-name-prefix = "SpkrLeft";
		firmware-name = "qcom/sm8250/ayn/thor/aw883xx_acf.bin";
	};
};

&i2c13 {
	status = "okay";
	clock-frequency = <100000>;

	touchscreen@38 {
		compatible = "focaltech,ft5426";
		reg = <0x38>;
		#address-cells = <1>;
		#size-cells = <0>;

		interrupt-parent = <&tlmm>;
		interrupts = <39 IRQ_TYPE_EDGE_FALLING>;

		reset-gpios = <&tlmm 38 GPIO_ACTIVE_LOW>;

		vcc-supply = <&vreg_l13a_ts1_3p0>;
		iovcc-supply = <&vreg_l1c_ts1_1p8>;

		pinctrl-0 = <&ts_p_rst_default &ts_p_int_default>;
		pinctrl-1 = <&ts_p_rst_sleep &ts_p_int_sleep>;
		pinctrl-names = "default", "sleep";

		label = "top_touchscreen";
		touchscreen-size-x = <1080>;
		touchscreen-size-y = <1920>;
		touchscreen-swapped-x-y;
		touchscreen-inverted-x;
	};
};

&mdss {
	status = "okay";
};

&mdss_dp {
	status = "disabled";
};

&mdss_dp_out {
	data-lanes = <0 1>;
	remote-endpoint = <&usb_1_qmpphy_dp_in>;
};

&mdss_dsi0 {
	status = "okay";
	vdda-supply = <&vreg_l9a_1p2>;

	panel@0 {
		reg = <0>;
		compatible = "chipone,icna3520";

		pinctrl-0 = <&dsi_p_rst_active>, <&dsi_p_te_active>;
		pinctrl-1 = <&dsi_p_rst_suspend>, <&dsi_p_te_suspend>;
		pinctrl-names = "default", "sleep";

		vdd-supply = <&mipi_vdd>;
		vddio-supply = <&vreg_l14a_1p8>;
		disp-supply = <&avdd_panel>;
		blvdd-supply = <&vdd_bl_5v0>;

		reset-gpios = <&tlmm 75 GPIO_ACTIVE_LOW>;

		rotation = <90>;

		port {
			panel0_in: endpoint {
				remote-endpoint = <&mdss_dsi0_out>;
			};
		};
	};
};

&mdss_dsi0_out {
	remote-endpoint = <&panel0_in>;
	data-lanes = <0 1 2 3>;
};

&mdss_dsi0_phy {
	vdds-supply = <&vreg_l5a_0p88>;
	status = "okay";
};

&mdss_dsi1 {
	status = "okay";
	vdda-supply = <&vreg_l9a_1p2>;

	panel@0 {
		reg = <0>;
		compatible = "ch13726a,thor";

    	pinctrl-0 = <&dsi_s_rst_active>, <&dsi_s_te_active>;
    	pinctrl-1 = <&dsi_s_rst_suspend>, <&dsi_s_te_suspend>;
    	pinctrl-names = "default", "sleep";

		vdd1v2-supply = <&vreg_l3c_1p2>;
		vddio-supply = <&display_sec_panel_vddio>;
		vdd-supply = <&vreg_l7c_2p85>;

		reset-gpios = <&tlmm 136 GPIO_ACTIVE_HIGH>;

		rotation = <90>;

		port {
			panel1_in: endpoint {
				remote-endpoint = <&mdss_dsi1_out>;
			};
		};
	};
};

&mdss_dsi1_out {
	data-lanes = <0 1 2 3>;
	remote-endpoint = <&panel1_in>;
};

&mdss_dsi1_phy {
	status = "okay";
	vdds-supply = <&vreg_l5a_0p88>;
};

