From fe5f057641bd41d5e86e90133424e289d6c50f8a Mon Sep 17 00:00:00 2001
From: Philippe Simons <simons.philippe@gmail.com>
Date: Tue, 6 Jan 2026 20:53:09 +0100
Subject: [PATCH] input:misc: add clk vibrator

---
 drivers/input/misc/Kconfig     |  11 ++
 drivers/input/misc/Makefile    |   1 +
 drivers/input/misc/clk-vibra.c | 185 +++++++++++++++++++++++++++++++++
 3 files changed, 197 insertions(+)
 create mode 100644 drivers/input/misc/clk-vibra.c

diff --git a/drivers/input/misc/Kconfig b/drivers/input/misc/Kconfig
index cc2558630797..4ac68ec531b9 100644
--- a/drivers/input/misc/Kconfig
+++ b/drivers/input/misc/Kconfig
@@ -648,6 +648,17 @@ config INPUT_PWM_VIBRA
 	  To compile this driver as a module, choose M here: the module will be
 	  called pwm-vibra.
 
+config INPUT_CLK_VIBRA
+	tristate "Clock-based vibrator support"
+	select INPUT_FF_MEMLESS
+	help
+	  Say Y here to get support for clock-based vibrator devices.
+
+	  If unsure, say N.
+
+	  To compile this driver as a module, choose M here: the module will be
+	  called clk-vibra.
+
 config INPUT_RK805_PWRKEY
 	tristate "Rockchip RK805 PMIC power key support"
 	depends on MFD_RK8XX
diff --git a/drivers/input/misc/Makefile b/drivers/input/misc/Makefile
index f5ebfa9d9983..3942766c6ea9 100644
--- a/drivers/input/misc/Makefile
+++ b/drivers/input/misc/Makefile
@@ -25,6 +25,7 @@ obj-$(CONFIG_INPUT_ATMEL_CAPTOUCH)	+= atmel_captouch.o
 obj-$(CONFIG_INPUT_AW86927)		+= aw86927.o
 obj-$(CONFIG_INPUT_BBNSM_PWRKEY)	+= nxp-bbnsm-pwrkey.o
 obj-$(CONFIG_INPUT_BMA150)		+= bma150.o
+obj-$(CONFIG_INPUT_CLK_VIBRA)		+= clk-vibra.o
 obj-$(CONFIG_INPUT_CM109)		+= cm109.o
 obj-$(CONFIG_INPUT_CMA3000)		+= cma3000_d0x.o
 obj-$(CONFIG_INPUT_CMA3000_I2C)		+= cma3000_d0x_i2c.o
diff --git a/drivers/input/misc/clk-vibra.c b/drivers/input/misc/clk-vibra.c
new file mode 100644
index 000000000000..91a3a369f9bf
--- /dev/null
+++ b/drivers/input/misc/clk-vibra.c
@@ -0,0 +1,185 @@
+#include <linux/module.h>
+#include <linux/platform_device.h>
+#include <linux/input.h>
+#include <linux/clk.h>
+#include <linux/slab.h>
+#include <linux/workqueue.h>
+#include <linux/err.h>
+#include <linux/regulator/consumer.h>
+#include <linux/of.h>
+
+struct clk_vibrator {
+	struct input_dev *input;
+	struct clk *clk;
+	struct regulator *vcc;
+
+	struct work_struct play_work;
+	u16 magnitude;
+	bool enabled;
+	bool vcc_on;
+	u32 vibration_freq_hz;
+};
+
+static int clk_vibrator_start(struct clk_vibrator *vibrator)
+{	
+	int ret;
+
+	/* Set the duty cycle to control intensity */
+	ret = clk_set_duty_cycle(vibrator->clk, vibrator->magnitude, 0xffff);
+	if (ret) {
+		dev_err(&vibrator->input->dev, "Failed to set duty cycle: %d\n", ret);
+		return ret;
+	}
+
+	if (!vibrator->enabled) {
+		if (!vibrator->vcc_on) {
+			ret = regulator_enable(vibrator->vcc);
+			if (ret) {
+				dev_err(&vibrator->input->dev, "failed to enable regulator: %d\n", ret);
+			} else {
+				vibrator->vcc_on = true;
+			}
+		}
+		ret = clk_prepare_enable(vibrator->clk);
+		if (ret) {
+			dev_err(&vibrator->input->dev, "Failed to enable clock: %d\n", ret);
+		} else {
+			vibrator->enabled = true;
+		}
+	}
+
+	return 0;
+}
+
+static void clk_vibrator_stop(struct clk_vibrator *vibrator)
+{
+	/* Stop vibration */
+	if (vibrator->enabled) {
+		clk_disable_unprepare(vibrator->clk);
+		vibrator->enabled = false;
+	}
+	if (vibrator->vcc_on) {
+		regulator_disable(vibrator->vcc);
+		vibrator->vcc_on = false;
+	}
+}
+
+static void clk_vibrator_play_work(struct work_struct *work)
+{
+	struct clk_vibrator *vibrator = container_of(work,
+					struct clk_vibrator, play_work);
+
+	if (vibrator->magnitude)
+		clk_vibrator_start(vibrator);
+	else
+		clk_vibrator_stop(vibrator);
+}
+
+static int clk_vibrator_play_effect(struct input_dev *dev, void *data,
+									struct ff_effect *effect)
+{
+	struct clk_vibrator *vibrator = input_get_drvdata(dev);
+
+	vibrator->magnitude = effect->u.rumble.strong_magnitude;
+	if (!vibrator->magnitude)
+		vibrator->magnitude = effect->u.rumble.weak_magnitude;
+	
+	/* Schedule the hardware update */
+	schedule_work(&vibrator->play_work);
+
+	return 0;
+}
+
+static void clk_vibrator_close(struct input_dev *input)
+{
+	struct clk_vibrator *vibrator = input_get_drvdata(input);
+
+	cancel_work_sync(&vibrator->play_work);
+	clk_vibrator_stop(vibrator);
+}
+
+static int clk_vibrator_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct clk_vibrator *vibrator;
+	int ret;
+
+	vibrator = devm_kzalloc(dev, sizeof(*vibrator), GFP_KERNEL);
+	if (!vibrator)
+		return -ENOMEM;
+
+	/* Get the clock defined in Device Tree */
+	vibrator->clk = devm_clk_get(dev, NULL);
+	if (IS_ERR(vibrator->clk)) {
+		return dev_err_probe(dev, PTR_ERR(vibrator->clk), "Failed to get clock\n");
+	}
+
+	vibrator->vcc = devm_regulator_get(dev, "vcc");
+	if (IS_ERR(vibrator->vcc))
+		return dev_err_probe(dev, PTR_ERR(vibrator->vcc),
+					 "Failed to request regulator\n");
+
+	/* Optional: Set a specific frequency if the motor requires resonance */
+	if (!device_property_read_u32(dev, "vibration-frequency-hz", &vibrator->vibration_freq_hz)) {
+		ret = clk_set_rate(vibrator->clk, vibrator->vibration_freq_hz);
+		if (ret)
+			dev_warn(dev, "Failed to set clock rate to %u Hz: %d\n", 
+					 vibrator->vibration_freq_hz, ret);
+	}
+
+	INIT_WORK(&vibrator->play_work, clk_vibrator_play_work);
+
+	/* Allocate Input Device */
+	vibrator->input = devm_input_allocate_device(dev);
+	if (!vibrator->input)
+		return -ENOMEM;
+
+	vibrator->input->name = "clk-vibrator";
+	vibrator->input->phys = "mangmi-air-x/vibrator0";
+	vibrator->input->id.bustype = BUS_HOST;
+	vibrator->input->dev.parent = dev;
+	vibrator->input->close = clk_vibrator_close;
+	
+	input_set_drvdata(vibrator->input, vibrator);
+
+	/* Configure Force Feedback capabilities */
+	input_set_capability(vibrator->input, EV_FF, FF_RUMBLE);
+	
+	ret = input_ff_create_memless(vibrator->input, NULL, clk_vibrator_play_effect);
+	if (ret) {
+		dev_err(dev, "Failed to create ff memless: %d\n", ret);
+		return ret;
+	}
+
+	ret = input_register_device(vibrator->input);
+	if (ret) {
+		dev_err(dev, "Failed to register input device: %d\n", ret);
+		return ret;
+	}
+
+	platform_set_drvdata(pdev, vibrator);
+	dev_info(dev, "Clock vibrator driver loaded\n");
+
+	return 0;
+}
+
+#ifdef CONFIG_OF
+static const struct of_device_id clk_vibra_dt_match_table[] = {
+	{ .compatible = "clk-vibrator" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, clk_vibra_dt_match_table);
+#endif
+
+static struct platform_driver clk_vibrator_driver = {
+	.probe = clk_vibrator_probe,
+	.driver = {
+		.name = "clk-vibrator",
+		.of_match_table = of_match_ptr(clk_vibra_dt_match_table),
+	},
+};
+module_platform_driver(clk_vibrator_driver);
+
+MODULE_AUTHOR("ROCKNIX");
+MODULE_DESCRIPTION("Vibrator driver using CLK API duty cycle");
+MODULE_LICENSE("GPL");
-- 
2.52.0

