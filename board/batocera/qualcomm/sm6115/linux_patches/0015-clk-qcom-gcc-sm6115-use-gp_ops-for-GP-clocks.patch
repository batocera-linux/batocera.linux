From: Xilin Wu <sophon@radxa.com>
Subject: [PATCH] clk: qcom: gcc-sm6115: switch GP clocks to clk_rcg2_gp_ops

Based on the equivalent sc7280 patch by Xilin Wu.
Link: https://lore.kernel.org/linux-arm-msm/20260406-gcc-gpclk-sc7280-2b412227c5fa@radxa.com/

Signed-off-by: Xilin Wu <sophon@radxa.com>
[adapted for gcc-sm6115.c]
---
 drivers/clk/qcom/gcc-sm6115.c | 10 +++-------
 1 file changed, 3 insertions(+), 7 deletions(-)

diff --git a/drivers/clk/qcom/gcc-sm6115.c b/drivers/clk/qcom/gcc-sm6115.c
--- a/drivers/clk/qcom/gcc-sm6115.c
+++ b/drivers/clk/qcom/gcc-sm6115.c
@@ -1060,10 +1060,6 @@
 };
 
 static const struct freq_tbl ftbl_gcc_gp1_clk_src[] = {
-	F(25000000, P_GPLL0_OUT_AUX2, 12, 0, 0),
-	F(50000000, P_GPLL0_OUT_AUX2, 6, 0, 0),
-	F(100000000, P_GPLL0_OUT_AUX2, 3, 0, 0),
-	F(200000000, P_GPLL0_OUT_AUX2, 1.5, 0, 0),
 	{ }
 };
 
@@ -1077,7 +1073,7 @@
 		.name = "gcc_gp1_clk_src",
 		.parent_data = gcc_parents_2,
 		.num_parents = ARRAY_SIZE(gcc_parents_2),
-		.ops = &clk_rcg2_ops,
+		.ops = &clk_rcg2_gp_ops,
 	},
 };
 
@@ -1091,7 +1087,7 @@
 		.name = "gcc_gp2_clk_src",
 		.parent_data = gcc_parents_2,
 		.num_parents = ARRAY_SIZE(gcc_parents_2),
-		.ops = &clk_rcg2_ops,
+		.ops = &clk_rcg2_gp_ops,
 	},
 };
 
@@ -1105,7 +1101,7 @@
 		.name = "gcc_gp3_clk_src",
 		.parent_data = gcc_parents_2,
 		.num_parents = ARRAY_SIZE(gcc_parents_2),
-		.ops = &clk_rcg2_ops,
+		.ops = &clk_rcg2_gp_ops,
 	},
 };
 
