diff --git a/drivers/gpu/drm/panel/panel-td4310.c b/drivers/gpu/drm/panel/panel-td4310.c
new file mode 100644
index 0000000..1cee63f
--- /dev/null
+++ b/drivers/gpu/drm/panel/panel-td4310.c
@@ -0,0 +1,250 @@
+// SPDX-License-Identifier: GPL-2.0-only
+// Copyright (c) 2025 Daniel Martin <dmanlfc@gmail.com>
+// Adapted from vendor device tree: td4310 video mode dsi video panel
+
+#include <linux/delay.h>
+#include <linux/gpio/consumer.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/regulator/consumer.h>
+
+#include <video/mipi_display.h>
+
+#include <drm/drm_mipi_dsi.h>
+#include <drm/drm_modes.h>
+#include <drm/drm_panel.h>
+#include <drm/drm_probe_helper.h>
+
+struct td4310 {
+	struct drm_panel panel;
+	struct mipi_dsi_device *dsi;
+	struct regulator_bulk_data *supplies;
+	struct gpio_desc *reset_gpio;
+	struct gpio_desc *enable_gpio;
+	enum drm_panel_orientation orientation;
+};
+
+static const struct regulator_bulk_data td4310_supplies[] = {
+	{ .supply = "vdd1" },
+	{ .supply = "avdd" },
+};
+
+static inline struct td4310 *to_td4310(struct drm_panel *panel)
+{
+	return container_of(panel, struct td4310, panel);
+}
+
+static void td4310_reset(struct td4310 *ctx)
+{
+	/* Based on qcom,mdss-dsi-reset-sequence = <0x01 0x0a 0x00 0x0a 0x01 0x0a> */
+	/* 1: De-assert (High), 0: Assert (Low), 1: De-assert (High) */
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
+	msleep(10);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+	msleep(10);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
+	msleep(10);
+}
+
+static int td4310_on(struct td4310 *ctx)
+{
+	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi };
+
+	ctx->dsi->mode_flags |= MIPI_DSI_MODE_LPM;
+
+	/* Exit Sleep mode (0x11) + 120ms delay */
+	mipi_dsi_dcs_exit_sleep_mode_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 120);
+
+	/* Set Display On (0x29) + 20ms delay */
+	mipi_dsi_dcs_set_display_on_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 20);
+
+	return dsi_ctx.accum_err;
+}
+
+static int td4310_off(struct td4310 *ctx)
+{
+	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi };
+
+	ctx->dsi->mode_flags &= ~MIPI_DSI_MODE_LPM;
+
+	/* Set Display Off (0x28) + 50ms delay */
+	mipi_dsi_dcs_set_display_off_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 50);
+
+	/* Enter Sleep mode (0x10) + 120ms delay */
+	mipi_dsi_dcs_enter_sleep_mode_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 120);
+
+	return dsi_ctx.accum_err;
+}
+
+static int td4310_prepare(struct drm_panel *panel)
+{
+	struct td4310 *ctx = to_td4310(panel);
+	struct device *dev = &ctx->dsi->dev;
+	int ret;
+
+	ret = regulator_bulk_enable(ARRAY_SIZE(td4310_supplies), ctx->supplies);
+	if (ret < 0) {
+		dev_err(panel->dev, "failed to enable regulators: %d\n", ret);
+		return ret;
+	}
+	msleep(20);
+
+	/* Turn on the enable GPIO if present */
+	gpiod_set_value_cansleep(ctx->enable_gpio, 1);
+	msleep(20);
+
+	td4310_reset(ctx);
+
+	ret = td4310_on(ctx);
+	if (ret < 0) {
+		dev_err(dev, "Failed to initialize panel: %d\n", ret);
+		gpiod_set_value_cansleep(ctx->enable_gpio, 0);
+		regulator_bulk_disable(ARRAY_SIZE(td4310_supplies), ctx->supplies);
+		return ret;
+	}
+
+	return 0;
+}
+
+static int td4310_unprepare(struct drm_panel *panel)
+{
+	struct td4310 *ctx = to_td4310(panel);
+	struct device *dev = &ctx->dsi->dev;
+	int ret;
+
+	ret = td4310_off(ctx);
+	if (ret < 0)
+		dev_err(dev, "Failed to un-initialize panel: %d\n", ret);
+
+	gpiod_set_value_cansleep(ctx->enable_gpio, 0);
+	regulator_bulk_disable(ARRAY_SIZE(td4310_supplies), ctx->supplies);
+
+	return 0;
+}
+
+static const struct drm_display_mode td4310_mode = {
+	.clock = (1080 + 50 + 4 + 50) * (1920 + 15 + 4 + 32) * 60 / 1000,
+	.hdisplay = 1080,
+	.hsync_start = 1080 + 50,
+	.hsync_end = 1080 + 50 + 4,
+	.htotal = 1080 + 50 + 4 + 50,
+	.vdisplay = 1920,
+	.vsync_start = 1920 + 15,
+	.vsync_end = 1920 + 15 + 4,
+	.vtotal = 1920 + 15 + 4 + 32,
+	.width_mm = 0,
+	.height_mm = 0,
+	.type = DRM_MODE_TYPE_DRIVER | DRM_MODE_TYPE_PREFERRED,
+};
+
+static int td4310_get_modes(struct drm_panel *panel,
+			      struct drm_connector *connector)
+{
+	return drm_connector_helper_get_modes_fixed(connector, &td4310_mode);
+}
+
+static enum drm_panel_orientation td4310_get_orientation(struct drm_panel *panel)
+{
+	struct td4310 *ctx = to_td4310(panel);
+
+	return ctx->orientation;
+}
+
+static const struct drm_panel_funcs td4310_panel_funcs = {
+	.prepare = td4310_prepare,
+	.unprepare = td4310_unprepare,
+	.get_modes = td4310_get_modes,
+	.get_orientation = td4310_get_orientation,
+};
+
+static int td4310_probe(struct mipi_dsi_device *dsi)
+{
+	struct device *dev = &dsi->dev;
+	struct td4310 *ctx;
+	int ret;
+
+	ctx = devm_kzalloc(dev, sizeof(*ctx), GFP_KERNEL);
+	if (!ctx)
+		return -ENOMEM;
+
+	ret = devm_regulator_bulk_get_const(dev, ARRAY_SIZE(td4310_supplies),
+		td4310_supplies, &ctx->supplies);
+	if (ret < 0){
+		return dev_err_probe(dev, ret, "Failed to get regulators\n");
+	}
+
+	ctx->reset_gpio = devm_gpiod_get(dev, "reset", GPIOD_OUT_HIGH);
+	if (IS_ERR(ctx->reset_gpio))
+		return dev_err_probe(dev, PTR_ERR(ctx->reset_gpio),
+				     "Failed to get reset-gpios\n");
+
+	ctx->enable_gpio = devm_gpiod_get(dev, "enable", GPIOD_OUT_HIGH);
+	if (IS_ERR(ctx->enable_gpio))
+		return dev_err_probe(dev, PTR_ERR(ctx->enable_gpio),
+				     "Failed to get enable-gpios\n");
+
+	ctx->dsi = dsi;
+	mipi_dsi_set_drvdata(dsi, ctx);
+
+	dsi->lanes = 4;
+	dsi->format = MIPI_DSI_FMT_RGB888;
+	
+	dsi->mode_flags = MIPI_DSI_MODE_VIDEO | MIPI_DSI_MODE_VIDEO_BURST | 
+	                  MIPI_DSI_MODE_LPM | MIPI_DSI_CLOCK_NON_CONTINUOUS;
+
+	/* Orientation */
+	ret = of_drm_get_panel_orientation(dev->of_node, &ctx->orientation);
+	if (ret < 0) {
+		ctx->orientation = DRM_MODE_PANEL_ORIENTATION_UNKNOWN;
+	}
+
+	drm_panel_init(&ctx->panel, dev, &td4310_panel_funcs,
+		       DRM_MODE_CONNECTOR_DSI);
+	ctx->panel.prepare_prev_first = true;
+
+	ret = drm_panel_of_backlight(&ctx->panel);
+	if (ret)
+		return dev_err_probe(dev, ret, "Failed to get backlight\n");
+
+	drm_panel_add(&ctx->panel);
+
+	ret = mipi_dsi_attach(dsi);
+	if (ret < 0) {
+		drm_panel_remove(&ctx->panel);
+		return dev_err_probe(dev, ret, "Failed to attach to DSI host\n");
+	}
+
+	return 0;
+}
+
+static void td4310_remove(struct mipi_dsi_device *dsi)
+{
+	struct td4310 *ctx = mipi_dsi_get_drvdata(dsi);
+	
+	mipi_dsi_detach(dsi);
+	drm_panel_remove(&ctx->panel);
+}
+
+static const struct of_device_id td4310_of_match[] = {
+	{ .compatible = "mangmi,td4310" },
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, td4310_of_match);
+
+static struct mipi_dsi_driver td4310_driver = {
+	.probe = td4310_probe,
+	.remove = td4310_remove,
+	.driver = {
+		.name = "panel-td4310",
+		.of_match_table = td4310_of_match,
+	},
+};
+module_mipi_dsi_driver(td4310_driver);
+
+MODULE_AUTHOR("Daniel Martin <dmanlfc@gmail.com> ");
+MODULE_DESCRIPTION("DRM driver for td4310 video mode dsi panel");
+MODULE_LICENSE("GPL");
