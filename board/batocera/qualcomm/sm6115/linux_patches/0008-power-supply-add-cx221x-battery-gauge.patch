From 687dbcc67dc4df3e0ee307dc2e18f887feec3be6 Mon Sep 17 00:00:00 2001
From: Philippe Simons <simons.philippe@gmail.com>
Date: Thu, 8 Jan 2026 08:42:40 +0100
Subject: [PATCH] power: supply: add CellWise CW221X battery gauge driver

Add support for CellWise CW2215/CW2217/CW2218 coulomb-counting
battery fuel gauge ICs. Based on Rockchip BSP driver by Xu Shengfei,
reworked to use regmap and devm managed resources.
---
 drivers/power/supply/Kconfig          |  11 +
 drivers/power/supply/Makefile         |   1 +
 drivers/power/supply/cw221x_battery.c | 554 ++++++++++++++++++++++++++++
 3 files changed, 566 insertions(+)
 create mode 100644 drivers/power/supply/cw221x_battery.c

diff --git a/drivers/power/supply/Kconfig b/drivers/power/supply/Kconfig
index dca4be23ee70..1c6609c5be36 100644
--- a/drivers/power/supply/Kconfig
+++ b/drivers/power/supply/Kconfig
@@ -141,6 +141,17 @@ config BATTERY_CW2015
 	  This driver can also be built as a module. If so, the module will be
 	  called cw2015_battery.

+config BATTERY_CW221X
+	tristate "CW221X Battery driver"
+	depends on I2C
+	select REGMAP_I2C
+	help
+	  Say Y here to enable support for the cellwise cw221x
+	  battery fuel gauge IC.
+
+	  This driver can also be built as a module. If so, the module will be
+	  called cw221x_battery.
+
 config BATTERY_DS2760
 	tristate "DS2760 battery driver (HP iPAQ & others)"
 	depends on W1
diff --git a/drivers/power/supply/Makefile b/drivers/power/supply/Makefile
index 99a820d38197..724d621d3d31 100644
--- a/drivers/power/supply/Makefile
+++ b/drivers/power/supply/Makefile
@@ -27,6 +27,7 @@ obj-$(CONFIG_CHARGER_AXP20X)	+= axp20x_ac_power.o
 obj-$(CONFIG_BATTERY_CHAGALL)	+= chagall-battery.o
 obj-$(CONFIG_BATTERY_CPCAP)	+= cpcap-battery.o
 obj-$(CONFIG_BATTERY_CW2015)	+= cw2015_battery.o
+obj-$(CONFIG_BATTERY_CW221X)	+= cw221x_battery.o
 obj-$(CONFIG_BATTERY_DS2760)	+= ds2760_battery.o
 obj-$(CONFIG_BATTERY_DS2780)	+= ds2780_battery.o
 obj-$(CONFIG_BATTERY_DS2781)	+= ds2781_battery.o
diff --git a/drivers/power/supply/cw221x_battery.c b/drivers/power/supply/cw221x_battery.c
new file mode 100644
index 000000000000..a1b2c3d4e5f6
--- /dev/null
+++ b/drivers/power/supply/cw221x_battery.c
@@ -0,0 +1,597 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Battery gauge driver for CellWise CW2215/CW2217/CW2218
+ *
+ * Copyright (c) 2022 Rockchip Electronics Co., Ltd.
+ * Author: Xu Shengfei <xsf@rock-chips.com>
+ */
+
+#include <linux/delay.h>
+#include <linux/devm-helpers.h>
+#include <linux/i2c.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/power_supply.h>
+#include <linux/regmap.h>
+#include <linux/workqueue.h>
+#include <linux/thermal.h>
+
+#define CW221X_REG_CHIP_ID		0x00
+#define CW221X_REG_VCELL_H		0x02
+#define CW221X_REG_SOC_INT		0x04
+#define CW221X_REG_TEMP		0x06
+#define CW221X_REG_MODE_CONFIG		0x08
+#define CW221X_REG_GPIO_CONFIG		0x0A
+#define CW221X_REG_SOC_ALERT		0x0B
+#define CW221X_REG_CURRENT_H		0x0E
+#define CW221X_REG_BAT_PROFILE		0x10
+#define CW221X_REG_CYCLE_H		0xA4
+#define CW221X_REG_SOH			0xA6
+#define CW221X_REG_IC_STATE		0xA7
+#define CW221X_REG_STB_CUR_H		0xA8
+#define CW221X_REG_FW_VERSION		0xAB
+
+#define CW221X_MODE_RESTART		0x30
+#define CW221X_MODE_ACTIVE		0x00
+#define CW221X_MODE_SLEEP		0xF0
+#define CW221X_UPDATE_FLAG		0x80
+#define CW221X_CHIP_ID			0xA0
+#define CW221X_IC_READY		0x0C
+
+#define CW221X_PROFILE_SIZE		80
+#define CW221X_DEFAULT_POLL_MS		5000
+
+/* FW version bits [7:6] identify chip variant */
+#define CW221X_FW_VARIANT_MASK		0xC0
+#define CW2215_VARIANT			0x80
+#define CW2217_VARIANT			0x40
+#define CW2218_VARIANT			0x00
+
+/* Default sense resistor: 10 mohm in micro-ohms */
+#define CW221X_DEFAULT_RSENSE_UOHM	10000
+
+struct cw221x {
+	struct device *dev;
+	struct regmap *regmap;
+	struct power_supply *battery;
+	struct delayed_work work;
+
+	u8 *profile;
+	int charge_full_design_uah;
+	u32 rsense_uohm;
+	u32 poll_interval_ms;
+	u8 fw_version;
+
+	int voltage_uv;
+	int soc;
+	int temp_decidegc;
+	int current_ua;
+	int stb_current_ua;
+	int cycle;
+	int soh;
+	int last_soc;
+};
+
+static const struct regmap_config cw221x_regmap_config = {
+	.reg_bits = 8,
+	.val_bits = 8,
+	.max_register = CW221X_REG_FW_VERSION,
+};
+
+static int cw221x_read_word(struct cw221x *cw, u8 reg, u16 *val)
+{
+	u8 buf[2];
+	int ret;
+
+	ret = regmap_bulk_read(cw->regmap, reg, buf, 2);
+	if (ret)
+		return ret;
+
+	*val = (buf[0] << 8) | buf[1];
+	return 0;
+}
+
+static int cw221x_set_mode(struct cw221x *cw, u8 mode)
+{
+	int ret;
+
+	ret = regmap_write(cw->regmap, CW221X_REG_MODE_CONFIG,
+			   CW221X_MODE_RESTART);
+	if (ret)
+		return ret;
+	msleep(20); /* Datasheet: must be >= 20ms */
+
+	ret = regmap_write(cw->regmap, CW221X_REG_MODE_CONFIG, mode);
+	if (ret)
+		return ret;
+	msleep(10);
+
+	return 0;
+}
+
+static int cw221x_load_profile(struct cw221x *cw)
+{
+	unsigned int reg_val;
+	int count = 0;
+	int ret, i;
+
+	ret = cw221x_set_mode(cw, CW221X_MODE_SLEEP);
+	if (ret)
+		return ret;
+
+	for (i = 0; i < CW221X_PROFILE_SIZE; i++) {
+		ret = regmap_write(cw->regmap, CW221X_REG_BAT_PROFILE + i,
+				   cw->profile[i]);
+		if (ret)
+			return ret;
+	}
+
+	/* Set update flag */
+	ret = regmap_write(cw->regmap, CW221X_REG_SOC_ALERT,
+			   CW221X_UPDATE_FLAG);
+	if (ret)
+		return ret;
+
+	/* Disable all interrupts */
+	ret = regmap_write(cw->regmap, CW221X_REG_GPIO_CONFIG, 0);
+	if (ret)
+		return ret;
+
+	ret = cw221x_set_mode(cw, CW221X_MODE_ACTIVE);
+	if (ret)
+		return ret;
+
+	/* Wait for IC to become ready (up to 5 seconds) */
+	while (count++ < 50) {
+		msleep(100);
+		ret = regmap_read(cw->regmap, CW221X_REG_IC_STATE, &reg_val);
+		if (ret)
+			return ret;
+		if ((reg_val & CW221X_IC_READY) == CW221X_IC_READY)
+			return 0;
+	}
+
+	cw221x_set_mode(cw, CW221X_MODE_SLEEP);
+	return -ETIMEDOUT;
+}
+
+static bool cw221x_profile_needs_update(struct cw221x *cw)
+{
+	unsigned int reg_val;
+	int ret, i;
+
+	ret = regmap_read(cw->regmap, CW221X_REG_MODE_CONFIG, &reg_val);
+	if (ret)
+		return false;
+	if (reg_val != CW221X_MODE_ACTIVE)
+		return true;
+
+	ret = regmap_read(cw->regmap, CW221X_REG_SOC_ALERT, &reg_val);
+	if (ret)
+		return false;
+	if (!(reg_val & CW221X_UPDATE_FLAG))
+		return true;
+
+	for (i = 0; i < CW221X_PROFILE_SIZE; i++) {
+		ret = regmap_read(cw->regmap, CW221X_REG_BAT_PROFILE + i,
+				  &reg_val);
+		if (ret)
+			return false;
+		if (cw->profile[i] != (u8)reg_val)
+			return true;
+	}
+
+	return false;
+}
+
+static int cw221x_update_data(struct cw221x *cw)
+{
+	unsigned int reg_val;
+	u16 raw;
+	int ret;
+
+	/* Voltage: 14-bit ADC, 312.5uV LSB */
+	ret = cw221x_read_word(cw, CW221X_REG_VCELL_H, &raw);
+	if (ret)
+		return ret;
+	cw->voltage_uv = raw * 5000 / 16;
+
+	/* SOC: high byte = integer %, low byte = 1/256 % fractional */
+	ret = cw221x_read_word(cw, CW221X_REG_SOC_INT, &raw);
+	if (ret)
+		return ret;
+	cw->soc = clamp((int)((raw + 128) / 256), 0, 100);
+
+	/* Temperature: -40 + reg/2 degC, report in decidegrees */
+	ret = regmap_read(cw->regmap, CW221X_REG_TEMP, &reg_val);
+	if (ret)
+		return ret;
+	cw->temp_decidegc = (int)reg_val * 5 - 400;
+
+	/*
+	 * Current: signed 16-bit across sense resistor.
+	 * Full-scale shunt voltage: 52.4mV (CW2215/CW2217) or 125mV (CW2218).
+	 * current_uA = raw * full_scale_uV / 32768 / rsense_ohm
+	 *            = raw * factor / rsense_uohm
+	 * CW2215/CW2217 factor: 52400*1000/32768 ≈ 1600
+	 * CW2218 factor:       125000*1000/32768 ≈ 3815
+	 */
+	ret = cw221x_read_word(cw, CW221X_REG_CURRENT_H, &raw);
+	if (ret)
+		return ret;
+	switch (cw->fw_version & CW221X_FW_VARIANT_MASK) {
+	case CW2215_VARIANT:
+	case CW2217_VARIANT:
+		cw->current_ua = (int)((s16)raw * 1600000LL /
+				 cw->rsense_uohm);
+		break;
+	case CW2218_VARIANT:
+		if (!cw->fw_version) {
+			cw->current_ua = 0;
+			break;
+		}
+		cw->current_ua = (int)((s16)raw * 3815000LL /
+				 cw->rsense_uohm);
+		break;
+	default:
+		cw->current_ua = 0;
+		break;
+	}
+
+	ret = cw221x_read_word(cw, CW221X_REG_STB_CUR_H, &raw);
+	if (ret)
+		return ret;
+	switch (cw->fw_version & CW221X_FW_VARIANT_MASK) {
+	case CW2215_VARIANT:
+	case CW2217_VARIANT:
+		cw->stb_current_ua = (int)((s16)raw * 1600000LL /
+					   cw->rsense_uohm);
+		break;
+	case CW2218_VARIANT:
+		if (!cw->fw_version) {
+			cw->stb_current_ua = 0;
+			break;
+		}
+		cw->stb_current_ua = (int)((s16)raw * 3815000LL /
+					   cw->rsense_uohm);
+		break;
+	default:
+		cw->stb_current_ua = 0;
+		break;
+	}
+
+	/* Cycle count: LSB = 1/16 cycle */
+	ret = cw221x_read_word(cw, CW221X_REG_CYCLE_H, &raw);
+	if (ret)
+		return ret;
+	cw->cycle = raw / 16;
+
+	/* SOH: 0-100% */
+	ret = regmap_read(cw->regmap, CW221X_REG_SOH, &reg_val);
+	if (ret)
+		return ret;
+	cw->soh = reg_val;
+
+	dev_dbg(cw->dev, "V=%duV SOC=%d%% T=%ddC I=%duA cyc=%d soh=%d%%\n",
+		cw->voltage_uv, cw->soc, cw->temp_decidegc,
+		cw->current_ua, cw->cycle, cw->soh);
+
+	return 0;
+}
+
+static int cw221x_check_active(struct cw221x *cw)
+{
+	unsigned int reg_val;
+	int ret;
+
+	ret = regmap_read(cw->regmap, CW221X_REG_MODE_CONFIG, &reg_val);
+	if (ret)
+		return ret;
+
+	if (reg_val == CW221X_MODE_ACTIVE)
+		return 0;
+
+	dev_warn(cw->dev, "IC in sleep mode (0x%02x), re-activating\n",
+		 reg_val);
+
+	if (cw->profile && cw221x_profile_needs_update(cw))
+		return cw221x_load_profile(cw);
+
+	return cw221x_set_mode(cw, CW221X_MODE_ACTIVE);
+}
+
+static void cw221x_work_func(struct work_struct *work)
+{
+	struct cw221x *cw = container_of(work, struct cw221x, work.work);
+
+	if (cw221x_check_active(cw)) {
+		dev_err(cw->dev, "failed to re-activate IC\n");
+		goto reschedule;
+	}
+
+	if (cw221x_update_data(cw))
+		dev_err(cw->dev, "failed to update data\n");
+
+	if (cw->soc != cw->last_soc) {
+		cw->last_soc = cw->soc;
+		power_supply_changed(cw->battery);
+	}
+
+reschedule:
+	schedule_delayed_work(&cw->work,
+			      msecs_to_jiffies(cw->poll_interval_ms));
+}
+
+static int cw221x_get_property(struct power_supply *psy,
+			       enum power_supply_property psp,
+			       union power_supply_propval *val)
+{
+	struct cw221x *cw = power_supply_get_drvdata(psy);
+
+	switch (psp) {
+	case POWER_SUPPLY_PROP_STATUS:
+		if (cw->soc == 100 && power_supply_is_system_supplied())
+			val->intval = POWER_SUPPLY_STATUS_FULL;
+		else if (power_supply_is_system_supplied())
+			val->intval = POWER_SUPPLY_STATUS_CHARGING;
+		else
+			val->intval = POWER_SUPPLY_STATUS_DISCHARGING;
+		break;
+	case POWER_SUPPLY_PROP_PRESENT:
+		val->intval = cw->voltage_uv > 0;
+		break;
+	case POWER_SUPPLY_PROP_VOLTAGE_NOW:
+		val->intval = cw->voltage_uv;
+		break;
+	case POWER_SUPPLY_PROP_CURRENT_NOW:
+		val->intval = cw->current_ua;
+		break;
+	case POWER_SUPPLY_PROP_CURRENT_AVG:
+		val->intval = cw->stb_current_ua;
+		break;
+	case POWER_SUPPLY_PROP_CAPACITY:
+		val->intval = cw->soc;
+		break;
+	case POWER_SUPPLY_PROP_CAPACITY_LEVEL:
+		if (cw->soc < 1 && !power_supply_is_system_supplied())
+			val->intval = POWER_SUPPLY_CAPACITY_LEVEL_CRITICAL;
+		else if (cw->soc <= 20)
+			val->intval = POWER_SUPPLY_CAPACITY_LEVEL_LOW;
+		else if (cw->soc <= 70)
+			val->intval = POWER_SUPPLY_CAPACITY_LEVEL_NORMAL;
+		else if (cw->soc <= 90)
+			val->intval = POWER_SUPPLY_CAPACITY_LEVEL_HIGH;
+		else
+			val->intval = POWER_SUPPLY_CAPACITY_LEVEL_FULL;
+		break;
+	case POWER_SUPPLY_PROP_TEMP:
+		val->intval = cw->temp_decidegc;
+		break;
+	case POWER_SUPPLY_PROP_CHARGE_FULL_DESIGN:
+		val->intval = cw->charge_full_design_uah;
+		break;
+	case POWER_SUPPLY_PROP_CHARGE_FULL:
+		val->intval = cw->charge_full_design_uah * cw->soh / 100;
+		break;
+	case POWER_SUPPLY_PROP_CHARGE_NOW:
+		val->intval = cw->charge_full_design_uah * cw->soc / 100;
+		break;
+	case POWER_SUPPLY_PROP_CYCLE_COUNT:
+		val->intval = cw->cycle;
+		break;
+	case POWER_SUPPLY_PROP_HEALTH:
+		val->intval = POWER_SUPPLY_HEALTH_GOOD;
+		break;
+	case POWER_SUPPLY_PROP_TECHNOLOGY:
+		val->intval = POWER_SUPPLY_TECHNOLOGY_LION;
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	return 0;
+}
+
+static int cw221x_get_temp(struct thermal_zone_device *tzd, int *temp)
+{
+	struct cw221x *cw = thermal_zone_device_priv(tzd);
+
+	*temp = cw->temp_decidegc * 100;
+	return 0;
+}
+
+static const struct thermal_zone_device_ops cw221x_thermal_ops = {
+	.get_temp = cw221x_get_temp,
+};
+
+static enum power_supply_property cw221x_properties[] = {
+	POWER_SUPPLY_PROP_STATUS,
+	POWER_SUPPLY_PROP_PRESENT,
+	POWER_SUPPLY_PROP_VOLTAGE_NOW,
+	POWER_SUPPLY_PROP_CURRENT_NOW,
+	POWER_SUPPLY_PROP_CURRENT_AVG,
+	POWER_SUPPLY_PROP_CAPACITY,
+	POWER_SUPPLY_PROP_CAPACITY_LEVEL,
+	POWER_SUPPLY_PROP_TEMP,
+	POWER_SUPPLY_PROP_CHARGE_FULL_DESIGN,
+	POWER_SUPPLY_PROP_CHARGE_FULL,
+	POWER_SUPPLY_PROP_CHARGE_NOW,
+	POWER_SUPPLY_PROP_CYCLE_COUNT,
+	POWER_SUPPLY_PROP_HEALTH,
+	POWER_SUPPLY_PROP_TECHNOLOGY,
+};
+
+static const struct power_supply_desc cw221x_psy_desc = {
+	.name = "battery",
+	.type = POWER_SUPPLY_TYPE_BATTERY,
+	.properties = cw221x_properties,
+	.num_properties = ARRAY_SIZE(cw221x_properties),
+	.get_property = cw221x_get_property,
+};
+
+static int cw221x_probe(struct i2c_client *client)
+{
+	struct power_supply_battery_info *bat_info;
+	struct power_supply_config psy_cfg = {};
+	struct cw221x *cw;
+	unsigned int reg_val;
+	int length, ret, retries;
+
+	cw = devm_kzalloc(&client->dev, sizeof(*cw), GFP_KERNEL);
+	if (!cw)
+		return -ENOMEM;
+
+	cw->dev = &client->dev;
+	cw->regmap = devm_regmap_init_i2c(client, &cw221x_regmap_config);
+	if (IS_ERR(cw->regmap))
+		return dev_err_probe(cw->dev, PTR_ERR(cw->regmap),
+				     "failed to init regmap\n");
+
+	i2c_set_clientdata(client, cw);
+
+	/* Verify chip ID */
+	ret = regmap_read(cw->regmap, CW221X_REG_CHIP_ID, &reg_val);
+	if (ret)
+		return dev_err_probe(cw->dev, ret, "failed to read chip ID\n");
+	if (reg_val != CW221X_CHIP_ID)
+		return dev_err_probe(cw->dev, -ENODEV,
+				     "unexpected chip ID 0x%02x\n", reg_val);
+
+	/* Sense resistor value from DT, default 10 mohm */
+	if (device_property_read_u32(cw->dev,
+				     "cellwise,sense-resistor-micro-ohms",
+				     &cw->rsense_uohm))
+		cw->rsense_uohm = CW221X_DEFAULT_RSENSE_UOHM;
+
+	/* Poll interval from DT, default 5s */
+	if (device_property_read_u32(cw->dev,
+				     "cellwise,monitor-interval-ms",
+				     &cw->poll_interval_ms))
+		cw->poll_interval_ms = CW221X_DEFAULT_POLL_MS;
+
+	/* Battery profile from DT */
+	length = device_property_count_u8(cw->dev, "cellwise,battery-profile");
+	if (length == CW221X_PROFILE_SIZE) {
+		cw->profile = devm_kzalloc(cw->dev, length, GFP_KERNEL);
+		if (!cw->profile)
+			return -ENOMEM;
+		ret = device_property_read_u8_array(cw->dev,
+						    "cellwise,battery-profile",
+						    cw->profile, length);
+		if (ret)
+			return ret;
+	} else if (length > 0) {
+		return dev_err_probe(cw->dev, -EINVAL,
+				     "battery-profile must be %d bytes\n",
+				     CW221X_PROFILE_SIZE);
+	}
+
+	/* Initialize IC: load profile if needed */
+	for (retries = 0; retries < 3; retries++) {
+		if (cw->profile && cw221x_profile_needs_update(cw)) {
+			dev_info(cw->dev, "loading battery profile\n");
+			ret = cw221x_load_profile(cw);
+		} else {
+			ret = regmap_read(cw->regmap, CW221X_REG_MODE_CONFIG,
+					  &reg_val);
+			if (!ret && reg_val != CW221X_MODE_ACTIVE)
+				ret = cw221x_set_mode(cw, CW221X_MODE_ACTIVE);
+		}
+		if (!ret)
+			break;
+		msleep(200);
+	}
+	if (ret)
+		return dev_err_probe(cw->dev, ret, "failed to initialize\n");
+
+	/* Read FW version for chip variant identification */
+	ret = regmap_read(cw->regmap, CW221X_REG_FW_VERSION, &reg_val);
+	if (ret)
+		return ret;
+	cw->fw_version = reg_val;
+
+	/* Initial data read */
+	ret = cw221x_update_data(cw);
+	if (ret)
+		return dev_err_probe(cw->dev, ret, "failed initial data read\n");
+	cw->last_soc = cw->soc;
+
+	/* Register power supply */
+	psy_cfg.drv_data = cw;
+	cw->battery = devm_power_supply_register(cw->dev, &cw221x_psy_desc,
+						 &psy_cfg);
+	if (IS_ERR(cw->battery))
+		return dev_err_probe(cw->dev, PTR_ERR(cw->battery),
+				     "failed to register battery\n");
+
+	devm_thermal_of_zone_register(cw->dev, 0, cw, &cw221x_thermal_ops);
+
+	/* Read battery design capacity from monitored-battery phandle */
+	if (!power_supply_get_battery_info(cw->battery, &bat_info)) {
+		if (bat_info->charge_full_design_uah > 0)
+			cw->charge_full_design_uah =
+				bat_info->charge_full_design_uah;
+	}
+
+	/* Start polling */
+	ret = devm_delayed_work_autocancel(cw->dev, &cw->work,
+					   cw221x_work_func);
+	if (ret)
+		return ret;
+	schedule_delayed_work(&cw->work, msecs_to_jiffies(50));
+
+	dev_info(cw->dev, "CW221%c (FW 0x%02x) rsense=%u uohm design=%d uAh\n",
+		 (cw->fw_version & CW221X_FW_VARIANT_MASK) == CW2215_VARIANT
+			? '5' :
+		 (cw->fw_version & CW221X_FW_VARIANT_MASK) == CW2217_VARIANT
+			? '7' : '8',
+		 cw->fw_version, cw->rsense_uohm, cw->charge_full_design_uah);
+
+	return 0;
+}
+
+static int cw221x_suspend(struct device *dev)
+{
+	struct cw221x *cw = dev_get_drvdata(dev);
+
+	cancel_delayed_work_sync(&cw->work);
+	return 0;
+}
+
+static int cw221x_resume(struct device *dev)
+{
+	struct cw221x *cw = dev_get_drvdata(dev);
+
+	schedule_delayed_work(&cw->work, msecs_to_jiffies(20));
+	return 0;
+}
+
+static DEFINE_SIMPLE_DEV_PM_OPS(cw221x_pm_ops,
+				cw221x_suspend, cw221x_resume);
+
+static const struct of_device_id cw221x_of_match[] = {
+	{ .compatible = "cellwise,cw221x" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, cw221x_of_match);
+
+static const struct i2c_device_id cw221x_id[] = {
+	{ "cw221x" },
+	{ }
+};
+MODULE_DEVICE_TABLE(i2c, cw221x_id);
+
+static struct i2c_driver cw221x_driver = {
+	.driver = {
+		.name = "cw221x-battery",
+		.pm = pm_sleep_ptr(&cw221x_pm_ops),
+		.of_match_table = cw221x_of_match,
+	},
+	.probe = cw221x_probe,
+	.id_table = cw221x_id,
+};
+module_i2c_driver(cw221x_driver);
+
+MODULE_AUTHOR("Xu Shengfei <xsf@rock-chips.com>");
+MODULE_DESCRIPTION("CellWise CW2215/CW2217/CW2218 battery gauge driver");
