Subject: [PATCH] ASoC: es8326: derive sysclk from MCLK and balance bias_level
 clk usage

---
 sound/soc/codecs/es8326.c | 24 ++++++++++++++----------
 1 file changed, 14 insertions(+), 10 deletions(-)

diff --git a/sound/soc/codecs/es8326.c b/sound/soc/codecs/es8326.c
--- a/sound/soc/codecs/es8326.c
+++ b/sound/soc/codecs/es8326.c
@@ -676,14 +676,11 @@ static int es8326_set_bias_level(struct snd_soc_component *codec,
 				 enum snd_soc_bias_level level)
 {
 	struct es8326_priv *es8326 = snd_soc_component_get_drvdata(codec);
+	struct snd_soc_dapm_context *dapm = snd_soc_component_to_dapm(codec);
 	int ret;
 
 	switch (level) {
 	case SND_SOC_BIAS_ON:
-		ret = clk_prepare_enable(es8326->mclk);
-		if (ret)
-			return ret;
-
 		regmap_update_bits(es8326->regmap, ES8326_RESET, 0x02, 0x02);
 		usleep_range(5000, 10000);
 		regmap_write(es8326->regmap, ES8326_INTOUT_IO, es8326->interrupt_clk);
@@ -701,6 +698,13 @@ static int es8326_set_bias_level(struct snd_soc_component *codec,
 	case SND_SOC_BIAS_PREPARE:
 		break;
 	case SND_SOC_BIAS_STANDBY:
+		if (snd_soc_dapm_get_bias_level(dapm) == SND_SOC_BIAS_OFF) {
+			ret = clk_prepare_enable(es8326->mclk);
+			if (ret) {
+				dev_err(codec->dev, "unable to enable mclk\n");
+				return ret;
+			}
+		}
 		regmap_write(es8326->regmap, ES8326_ANA_PDN, 0x3b);
 		regmap_update_bits(es8326->regmap, ES8326_CLK_CTL, 0x20, 0x00);
 		regmap_write(es8326->regmap, ES8326_SDINOUT1_IO, ES8326_IO_INPUT);
@@ -712,7 +716,8 @@ static int es8326_set_bias_level(struct snd_soc_component *codec,
 		regmap_update_bits(es8326->regmap, ES8326_CLK_MUX, 0x80, 0x80);
 		break;
 	case SND_SOC_BIAS_OFF:
-		clk_disable_unprepare(es8326->mclk);
+		if (snd_soc_dapm_get_bias_level(dapm) != SND_SOC_BIAS_OFF)
+			clk_disable_unprepare(es8326->mclk);
 		break;
 	}
 
@@ -1313,11 +1318,11 @@ static int es8326_i2c_probe(struct i2c_client *i2c)
 	if (!es8326->mclk)
 		dev_warn(&i2c->dev, "assuming static mclk\n");
 
-	ret = clk_prepare_enable(es8326->mclk);
-	if (ret) {
-		dev_err(&i2c->dev, "unable to enable mclk\n");
-		return ret;
-	}
+	if (es8326->mclk) {
+		es8326->sysclk = clk_get_rate(es8326->mclk);
+		if (!es8326->sysclk)
+			dev_warn(&i2c->dev, "mclk rate is 0, sysclk unset\n");
+	}
 	return devm_snd_soc_register_component(&i2c->dev,
 					&soc_component_dev_es8326,
 					&es8326_dai, 1);
--
2.43.1
