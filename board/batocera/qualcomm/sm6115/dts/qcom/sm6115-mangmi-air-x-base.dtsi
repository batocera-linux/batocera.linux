/dts-v1/;

#include <dt-bindings/leds/common.h>
#include <dt-bindings/sound/qcom,q6afe.h>
#include <dt-bindings/sound/qcom,q6asm.h>
#include <dt-bindings/usb/pd.h>
#include "sm6115.dtsi"
#include "pm6125.dtsi"

/ {
	chassis-type = "handset";

	aliases {
		mmc0 = &sdhc_2;
		serial0 = &uart4;
		hsuart0 = &uart3;
		hsuart1 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	battery: battery {
		compatible = "simple-battery";
		charge-full-design-microamp-hours = <5000000>;
		voltage-min-design-microvolt = <3400000>;
		voltage-max-design-microvolt = <4350000>;
		constant-charge-current-max-microamp = <3000000>;
		constant-charge-voltage-max-microvolt = <4350000>;
		precharge-current-microamp = <200000>;
		charge-term-current-microamp = <200000>;
	};

	fan: gpio-fan {
		compatible = "gpio-fan";
		gpio-fan,speed-map = <0 0>, <8600 1>;
		gpios = <&tlmm 92 GPIO_ACTIVE_HIGH>;
		#cooling-cells = <2>;
	};

	vibrator {
		compatible = "clk-vibrator";
		clocks = <&gcc GCC_GP1_CLK>;
		vcc-supply = <&vibra_vcc>;
		pinctrl-names = "default";
		pinctrl-0 = <&gpio_clk_pins>;
		vibration-frequency-hz = <10000>;
	};

	led_vdd: regulator-led-vdd {
		compatible = "regulator-fixed";
		regulator-name = "led-vdd";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&tlmm 23 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		pinctrl-names = "default";
		pinctrl-0 = <&led_en_default>;
	};

	vibra_vcc: regulator-vibra-vcc {
		compatible = "regulator-fixed";
		regulator-name = "vibra_vcc";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&tlmm 96 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		pinctrl-names = "default";
		pinctrl-0 = <&vibra_vcc_default>;
	};

	es8326_vdd_3v3: regulator-es8326-vdd {
		compatible = "regulator-fixed";
		regulator-name = "es8326-vdd-3v3";
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		gpio = <&tlmm 66 GPIO_ACTIVE_HIGH>;
		enable-active-high;
		regulator-always-on;
		regulator-boot-on;
		pinctrl-names = "default";
		pinctrl-0 = <&es8326_vdd_default>;
	};

	gpio-keys {
		compatible = "gpio-keys";

		pinctrl-names = "default";
		pinctrl-0 = <&vol_up_n>;

		key-volume-up {
			label = "Volume Up";
			linux,code = <KEY_VOLUMEUP>;
			gpios = <&pm6125_gpios 5 GPIO_ACTIVE_LOW>;
			debounce-interval = <15>;
			linux,can-disable;
			wakeup-source;
		};
	};

	vph_pwr: regulator-vph-pwr {
		compatible = "regulator-fixed";
		regulator-name = "vph_pwr";
		regulator-min-microvolt = <3700000>;
		regulator-max-microvolt = <3700000>;

		regulator-always-on;
		regulator-boot-on;
	};

	panel_backlight: backlight {
		compatible = "pwm-backlight";
		pwms = <&pm6125_pwm 0 40000>;

		brightness-levels = <0 204>;
		num-interpolated-steps = <204>;
		max-brightness = <204>;
		default-brightness-level = <204>;
	};

	multi-led-l1 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l1"; leds = <&left_red_1>, <&left_green_1>, <&left_blue_1>; };
	multi-led-l2 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l2"; leds = <&left_red_2>, <&left_green_2>, <&left_blue_2>; };
	multi-led-l3 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l3"; leds = <&left_red_3>, <&left_green_3>, <&left_blue_3>; };
	multi-led-l4 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l4"; leds = <&left_red_4>, <&left_green_4>, <&left_blue_4>; };
	multi-led-l5 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l5"; leds = <&left_red_5>, <&left_green_5>, <&left_blue_5>; };
	multi-led-l6 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l6"; leds = <&left_red_6>, <&left_green_6>, <&left_blue_6>; };
	multi-led-l7 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l7"; leds = <&left_red_7>, <&left_green_7>, <&left_blue_7>; };
	multi-led-l8 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l8"; leds = <&left_red_8>, <&left_green_8>, <&left_blue_8>; };
	multi-led-l9 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "l9"; leds = <&left_red_9>, <&left_green_9>, <&left_blue_9>; };

	multi-led-r1 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r1"; leds = <&right_red_1>, <&right_green_1>, <&right_blue_1>; };
	multi-led-r2 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r2"; leds = <&right_red_2>, <&right_green_2>, <&right_blue_2>; };
	multi-led-r3 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r3"; leds = <&right_red_3>, <&right_green_3>, <&right_blue_3>; };
	multi-led-r4 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r4"; leds = <&right_red_4>, <&right_green_4>, <&right_blue_4>; };
	multi-led-r5 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r5"; leds = <&right_red_5>, <&right_green_5>, <&right_blue_5>; };
	multi-led-r6 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r6"; leds = <&right_red_6>, <&right_green_6>, <&right_blue_6>; };
	multi-led-r7 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r7"; leds = <&right_red_7>, <&right_green_7>, <&right_blue_7>; };
	multi-led-r8 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r8"; leds = <&right_red_8>, <&right_green_8>, <&right_blue_8>; };
	multi-led-r9 { compatible = "leds-group-multicolor"; color = <LED_COLOR_ID_RGB>; function = "r9"; leds = <&right_red_9>, <&right_green_9>, <&right_blue_9>; };

	wcn3950-pmu {
		compatible = "qcom,wcn3950-pmu";

		pinctrl-0 = <&sw_ctrl_default>;
		pinctrl-names = "default";

		vddio-supply = <&vreg_l9a_1p8>;
		vddxo-supply = <&vreg_l16a_1p3>;
		vddrf-supply = <&vreg_l17a_1p3>;
		vddch0-supply = <&vreg_l23a_3p3>;

		swctrl-gpios = <&tlmm 87 GPIO_ACTIVE_HIGH>;

		regulators {
			vreg_pmu_io: ldo0 {
				regulator-name = "vreg_pmu_io";
			};

			vreg_pmu_xo: ldo1 {
				regulator-name = "vreg_pmu_xo";
			};

			vreg_pmu_rf: ldo2 {
				regulator-name = "vreg_pmu_rf";
			};

			vreg_pmu_ch0: ldo3 {
				regulator-name = "vreg_pmu_ch0";
			};
		};
	};

	sound {
		compatible = "qcom,qrb4210-rb2-sndcard";
		model = "MangmiAirX";

		widgets = "Speaker", "SPK_L Speaker",
			  "Speaker", "SPK_R Speaker";

		pin-switches = "SPK_L Speaker", "SPK_R Speaker";

		audio-routing = "SPK_L Speaker", "SPK_L DAC Output",
				"SPK_R Speaker", "SPK_R DAC Output",
				"Headphone Jack", "HPOL",
				"Headphone Jack", "HPOR";

		pinctrl-names = "default";
		pinctrl-0 = <&lpi_qua_mi2s_active>, <&lpi_i2s2_active>,
			    <&lpi_dmic23_active>;

		mm1-dai-link {
			link-name = "MultiMedia1";
			cpu {
				sound-dai = <&q6asmdai MSM_FRONTEND_DAI_MULTIMEDIA1>;
			};
		};

		mm2-dai-link {
			link-name = "MultiMedia2";
			cpu {
				sound-dai = <&q6asmdai MSM_FRONTEND_DAI_MULTIMEDIA2>;
			};
		};

		mm3-dai-link {
			link-name = "MultiMedia3";
			cpu {
				sound-dai = <&q6asmdai MSM_FRONTEND_DAI_MULTIMEDIA3>;
			};
		};

		sec-mi2s-playback-dai-link {
			link-name = "Secondary MI2S Playback";
			cpu {
				sound-dai = <&q6afedai SECONDARY_MI2S_RX>;
			};
			platform {
				sound-dai = <&q6routing>;
			};
			codec {
				sound-dai = <&aw88261_l>, <&aw88261_r>;
			};
		};

		quat-mi2s-playback-dai-link {
			link-name = "Quaternary MI2S Playback";
			cpu {
				sound-dai = <&q6afedai QUATERNARY_MI2S_RX>;
			};
			platform {
				sound-dai = <&q6routing>;
			};
			codec {
				sound-dai = <&es8326>;
			};
		};

		quat-mi2s-capture-dai-link {
			link-name = "Quaternary MI2S Capture";
			cpu {
				sound-dai = <&q6afedai QUATERNARY_MI2S_TX>;
			};
			platform {
				sound-dai = <&q6routing>;
			};
			codec {
				sound-dai = <&es8326>;
			};
		};

		mm4-capture-dai-link {
			link-name = "MultiMedia4 Capture";
			cpu {
				sound-dai = <&q6asmdai MSM_FRONTEND_DAI_MULTIMEDIA4>;
			};
		};

		mm5-capture-dai-link {
			link-name = "MultiMedia5 Capture";
			cpu {
				sound-dai = <&q6asmdai MSM_FRONTEND_DAI_MULTIMEDIA5>;
			};
		};

		va-codec-dma-dai-link {
			link-name = "VA_CODEC_DMA_TX_0";
			cpu {
				sound-dai = <&q6afedai VA_CODEC_DMA_TX_0>;
			};
			platform {
				sound-dai = <&q6routing>;
			};
			codec {
				sound-dai = <&vamacro 0>;
			};
		};
	};
};

&soc {
	rxmacro: codec@a600000 {
		compatible = "qcom,sm6115-lpass-rx-macro";
		reg = <0x0 0x0a600000 0x0 0x1000>;

		clocks = <&q6afecc LPASS_CLK_ID_RX_CORE_MCLK     LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&q6afecc LPASS_CLK_ID_RX_CORE_NPL_MCLK LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&q6afecc LPASS_HW_DCODEC_VOTE          LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&vamacro>;
		clock-names = "mclk", "npl", "dcodec", "fsgen";

		assigned-clocks = <&q6afecc LPASS_CLK_ID_RX_CORE_MCLK     LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
				  <&q6afecc LPASS_CLK_ID_RX_CORE_NPL_MCLK LPASS_CLK_ATTRIBUTE_COUPLE_NO>;
		assigned-clock-rates = <22579200>, <22579200>;

		#clock-cells = <0>;
		clock-output-names = "mclk";
		#sound-dai-cells = <1>;
	};

	txmacro: codec@a620000 {
		compatible = "qcom,sm6115-lpass-tx-macro";
		reg = <0x0 0x0a620000 0x0 0x1000>;

		clocks = <&q6afecc LPASS_CLK_ID_TX_CORE_MCLK     LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&q6afecc LPASS_CLK_ID_TX_CORE_NPL_MCLK LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&q6afecc LPASS_HW_DCODEC_VOTE          LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&vamacro>;
		clock-names = "mclk", "npl", "dcodec", "fsgen";

		assigned-clocks = <&q6afecc LPASS_CLK_ID_TX_CORE_MCLK     LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
				  <&q6afecc LPASS_CLK_ID_TX_CORE_NPL_MCLK LPASS_CLK_ATTRIBUTE_COUPLE_NO>;
		assigned-clock-rates = <19200000>, <19200000>;

		qcom,dmic-sample-rate = <2400000>;

		#clock-cells = <0>;
		clock-output-names = "mclk";
		#sound-dai-cells = <1>;
	};

	lpass_audiocc: clock-controller@a6a9000 {
		compatible = "qcom,sm6115-lpassaudiocc";
		reg = <0x0 0x0a6a9000 0x0 0x1000>;
		#reset-cells = <1>;
	};

	vamacro: codec@a730000 {
		compatible = "qcom,sm6115-lpass-va-macro";
		reg = <0x0 0x0a730000 0x0 0x1000>;

		clocks = <&q6afecc LPASS_CLK_ID_TX_CORE_MCLK     LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&q6afecc LPASS_HW_DCODEC_VOTE          LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
			 <&q6afecc LPASS_CLK_ID_TX_CORE_NPL_MCLK LPASS_CLK_ATTRIBUTE_COUPLE_NO>;
		clock-names = "mclk", "dcodec", "npl";

		assigned-clocks = <&q6afecc LPASS_CLK_ID_TX_CORE_MCLK     LPASS_CLK_ATTRIBUTE_COUPLE_NO>,
				  <&q6afecc LPASS_CLK_ID_TX_CORE_NPL_MCLK LPASS_CLK_ATTRIBUTE_COUPLE_NO>;
		assigned-clock-rates = <19200000>, <19200000>;

		qcom,dmic-sample-rate = <2400000>;

		#clock-cells = <0>;
		clock-output-names = "fsgen";
		#sound-dai-cells = <1>;
	};

	lpasscc: clock-controller@a7e0000 {
		compatible = "qcom,sm6115-lpasscc";
		reg = <0x0 0x0a7e0000 0x0 0x12000>;
		#reset-cells = <1>;
	};
};

&q6afedai {
	dai@18 {
		reg = <SECONDARY_MI2S_RX>;
		qcom,sd-lines = <0>;
	};

	dai@19 {
		reg = <SECONDARY_MI2S_TX>;
		qcom,sd-lines = <1>;
	};

	dai@22 {
		reg = <QUATERNARY_MI2S_RX>;
		qcom,sd-lines = <0>;
	};

	dai@23 {
		reg = <QUATERNARY_MI2S_TX>;
		qcom,sd-lines = <1>;
	};

	dai@110 {
		reg = <VA_CODEC_DMA_TX_0>;
	};
};

&q6asmdai {
	dai@3 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA4>;
	};

	dai@4 {
		reg = <MSM_FRONTEND_DAI_MULTIMEDIA5>;
	};
};

&i2c1 {
	status = "okay";
	clock-frequency = <400000>;

	panel_avdd: regulator@3e {
		reg = <0x3e>;
		compatible = "awinic,aw37503"; /* SGM3804 is a clone */
		status = "okay";

		panel_avdd_outp: outp {
			regulator-name = "panel-avdd-outp";
			regulator-min-microvolt = <5500000>;
			regulator-max-microvolt = <5500000>;
			regulator-active-discharge = <1>;
			enable-gpios = <&tlmm 44 GPIO_ACTIVE_HIGH>;
			vin-supply = <&vph_pwr>;
		};

		panel_avdd_outn: outn {
			regulator-name = "panel-avdd-outn";
			regulator-min-microvolt = <5500000>;
			regulator-max-microvolt = <5500000>;
			regulator-active-discharge = <1>;
			enable-gpios = <&tlmm 45 GPIO_ACTIVE_HIGH>;
			vin-supply = <&vph_pwr>;
		};
	};

	es8326: codec@18 {
		compatible = "everest,es8326";
		reg = <0x18>;
		clocks = <&q6afecc LPASS_CLK_ID_MCLK_1 LPASS_CLK_ATTRIBUTE_COUPLE_NO>;
		clock-names = "mclk";
		assigned-clocks = <&q6afecc LPASS_CLK_ID_MCLK_1 LPASS_CLK_ATTRIBUTE_COUPLE_NO>;
		assigned-clock-rates = <12288000>;
		interrupts-extended = <&tlmm 65 IRQ_TYPE_EDGE_FALLING>;
		vdd-supply = <&es8326_vdd_3v3>;
		everest,jack-detect-inverted;

		pinctrl-names = "default";
		pinctrl-0 = <&es8326_irq_default &lpi_ext_mclk0_b_active>;
		#sound-dai-cells = <0>;
		status = "okay";
	};

	aw88261_l: audio-codec@34 {
		compatible = "awinic,aw88261";
		reg = <0x34>;

		dvdd-supply = <&vreg_l9a_1p8>;

		interrupt-parent = <&tlmm>;
		interrupts = <106 IRQ_TYPE_LEVEL_LOW>;

		pinctrl-names = "default";
		pinctrl-0 = <&aw88261_left_irq_default>;

		awinic,audio-channel = <0>;
		awinic,sync-flag;
		sound-name-prefix = "SPK_L";
		firmware-name = "aw88261_acf.bin";

		#sound-dai-cells = <0>;
	};

	aw88261_r: audio-codec@35 {
		compatible = "awinic,aw88261";
		reg = <0x35>;

		dvdd-supply = <&vreg_l9a_1p8>;

		interrupt-parent = <&tlmm>;
		interrupts = <107 IRQ_TYPE_LEVEL_LOW>;

		pinctrl-names = "default";
		pinctrl-0 = <&aw88261_right_irq_default>;

		awinic,audio-channel = <1>;
		awinic,sync-flag;
		sound-name-prefix = "SPK_R";
		firmware-name = "aw88261_acf.bin";

		#sound-dai-cells = <0>;
	};

	fuel_gauge: fuel-gauge@64 {
		compatible = "cellwise,cw221x";
		reg = <0x64>;
		monitored-battery = <&battery>;
		#thermal-sensor-cells = <0>;
		cellwise,sense-resistor-micro-ohms = <10000>;
		cellwise,monitor-interval-ms = <5000>;
		cellwise,battery-profile = /bits/ 8 <
			0x5a 0x00 0x00 0x00 0x00 0x00 0x00 0x00
			0xad 0xbd 0xb3 0xba 0xa6 0xa2 0xd1 0xb3
			0x9e 0xff 0xe5 0xb7 0x8b 0x75 0x66 0x5e
			0x5c 0x5c 0x5c 0xa8 0x7c 0xdc 0x03 0xcf
			0xc8 0xcf 0xd0 0xd1 0xce 0xcd 0xca 0xcc
			0xc7 0xca 0xc1 0xa5 0x95 0x8a 0x81 0x77
			0x6b 0x68 0x7d 0x90 0x8e 0x84 0x8a 0x63
			0x20 0x00 0xab 0x10 0x00 0xb0 0x4d 0x00
			0x00 0x00 0x64 0x1f 0xd3 0x37 0x00 0x00
			0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x18>;
	};
};

&i2c5 {
	status = "okay";
	clock-frequency = <400000>;

	typec-port-controller@22 {
		compatible = "fcs,fusb302";
		reg = <0x22>;

		interrupts-extended = <&tlmm 39 IRQ_TYPE_LEVEL_LOW>;
		vbus-supply = <&usb_otg_vbus>;

		pinctrl-names = "default";
		pinctrl-0 = <&tcpc_irq_default>;

		connector {
			compatible = "usb-c-connector";
			label = "USB-C";
			pd-revision = /bits/ 8 <0x3 0x0 0x1 0x20>;
			self-powered;
			power-role = "dual";
			data-role = "dual";
			try-power-role = "sink";
			op-sink-microwatt = <10000000>;
			sink-pdos = <PDO_FIXED(5000, 3000, PDO_FIXED_DUAL_ROLE |
						      PDO_FIXED_USB_COMM |
						      PDO_FIXED_DATA_SWAP)
				PDO_PPS_APDO(4000, 11000, 3000)>;

			source-pdos = <PDO_FIXED(5000, 1200,
						 PDO_FIXED_DUAL_ROLE |
						 PDO_FIXED_DATA_SWAP |
						 PDO_FIXED_USB_COMM)>;

			pd-source-inputs = <0x04>;
			pd-battery-info = <0x01>;

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@0 {
					reg = <0>;
					usb_con_hs: endpoint {
						remote-endpoint = <&usb_dwc3_hs>;
					};
				};

				port@1 {
					reg = <1>;
					usb_con_ss: endpoint {
						remote-endpoint = <&usb_qmpphy_out>;
					};
				};
			};
		};
	};

	charger@1a {
		compatible = "sgmicro,sgm41515"; /* BQ25601D clone */
		reg = <0x1a>;
		monitored-battery = <&battery>;
		interrupts-extended = <&tlmm 70 IRQ_TYPE_EDGE_FALLING>;
		pinctrl-names = "default";
		pinctrl-0 = <&chg_int_default>, <&chg_en_default>;
		wakeup-source;

		input-voltage-limit-microvolt = <4500000>;

		status = "okay";

		usb_otg_vbus: usb-otg-vbus {
			regulator-name = "usb-otg-vbus";
			regulator-min-microvolt = <5000000>;
			regulator-max-microvolt = <5000000>;
		};
	};

	led-controller@3a {
		compatible = "awinic,aw20036";
		vdd-supply = <&led_vdd>;
		reg = <0x3a>;
		enable-gpios = <&tlmm 21 GPIO_ACTIVE_HIGH>;
		#address-cells = <1>;
		#size-cells = <0>;
		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&rgbl_activate>;
		pinctrl-1 = <&rgbl_suspend>;
		status = "okay";

		left_blue_1: led@0 { reg = <0x0>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_1"; led-max-microamp = <3400>; };
		left_green_1: led@1 { reg = <0x1>; color = <LED_COLOR_ID_GREEN>; label = "left_green_1"; led-max-microamp = <3400>; };
		left_red_1: led@2 { reg = <0x2>; color = <LED_COLOR_ID_RED>; label = "left_red_1"; led-max-microamp = <3400>; };

		left_blue_2: led@3 { reg = <0x3>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_2"; led-max-microamp = <3400>; };
		left_green_2: led@4 { reg = <0x4>; color = <LED_COLOR_ID_GREEN>; label = "left_green_2"; led-max-microamp = <3400>; };
		left_red_2: led@5 { reg = <0x5>; color = <LED_COLOR_ID_RED>; label = "left_red_2"; led-max-microamp = <3400>; };

		left_blue_3: led@6 { reg = <0x6>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_3"; led-max-microamp = <3400>; };
		left_green_3: led@7 { reg = <0x7>; color = <LED_COLOR_ID_GREEN>; label = "left_green_3"; led-max-microamp = <3400>; };
		left_red_3: led@8 { reg = <0x8>; color = <LED_COLOR_ID_RED>; label = "left_red_3"; led-max-microamp = <3400>; };

		left_blue_4: led@9 { reg = <0x9>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_4"; led-max-microamp = <3400>; };
		left_green_4: led@a { reg = <0xa>; color = <LED_COLOR_ID_GREEN>; label = "left_green_4"; led-max-microamp = <3400>; };
		left_red_4: led@b { reg = <0xb>; color = <LED_COLOR_ID_RED>; label = "left_red_4"; led-max-microamp = <3400>; };

		left_blue_5: led@c { reg = <0xc>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_5"; led-max-microamp = <3400>; };
		left_green_5: led@d { reg = <0xd>; color = <LED_COLOR_ID_GREEN>; label = "left_green_5"; led-max-microamp = <3400>; };
		left_red_5: led@e { reg = <0xe>; color = <LED_COLOR_ID_RED>; label = "left_red_5"; led-max-microamp = <3400>; };

		left_blue_6: led@f { reg = <0xf>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_6"; led-max-microamp = <3400>; };
		left_green_6: led@10 { reg = <0x10>; color = <LED_COLOR_ID_GREEN>; label = "left_green_6"; led-max-microamp = <3400>; };
		left_red_6: led@11 { reg = <0x11>; color = <LED_COLOR_ID_RED>; label = "left_red_6"; led-max-microamp = <3400>; };

		left_blue_7: led@12 { reg = <0x12>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_7"; led-max-microamp = <3400>; };
		left_green_7: led@13 { reg = <0x13>; color = <LED_COLOR_ID_GREEN>; label = "left_green_7"; led-max-microamp = <3400>; };
		left_red_7: led@14 { reg = <0x14>; color = <LED_COLOR_ID_RED>; label = "left_red_7"; led-max-microamp = <3400>; };

		left_blue_8: led@15 { reg = <0x15>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_8"; led-max-microamp = <3400>; };
		left_green_8: led@16 { reg = <0x16>; color = <LED_COLOR_ID_GREEN>; label = "left_green_8"; led-max-microamp = <3400>; };
		left_red_8: led@17 { reg = <0x17>; color = <LED_COLOR_ID_RED>; label = "left_red_8"; led-max-microamp = <3400>; };

		left_blue_9: led@18 { reg = <0x18>; color = <LED_COLOR_ID_BLUE>; label = "left_blue_9"; led-max-microamp = <3400>; };
		left_green_9: led@19 { reg = <0x19>; color = <LED_COLOR_ID_GREEN>; label = "left_green_9"; led-max-microamp = <3400>; };
		left_red_9: led@1a { reg = <0x1a>; color = <LED_COLOR_ID_RED>; label = "left_red_9"; led-max-microamp = <3400>; };
	};

	led-controller@3b {
		compatible = "awinic,aw20036";
		vdd-supply = <&led_vdd>;
		reg = <0x3b>;
		enable-gpios = <&tlmm 37 GPIO_ACTIVE_HIGH>;
		#address-cells = <1>;
		#size-cells = <0>;
		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&rgbr_activate>;
		pinctrl-1 = <&rgbr_suspend>;
		status = "okay";

		right_blue_1: led@0 { reg = <0x0>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_1"; led-max-microamp = <3400>; };
		right_green_1: led@1 { reg = <0x1>; color = <LED_COLOR_ID_GREEN>; label = "right_green_1"; led-max-microamp = <3400>; };
		right_red_1: led@2 { reg = <0x2>; color = <LED_COLOR_ID_RED>; label = "right_red_1"; led-max-microamp = <3400>; };

		right_blue_2: led@3 { reg = <0x3>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_2"; led-max-microamp = <3400>; };
		right_green_2: led@4 { reg = <0x4>; color = <LED_COLOR_ID_GREEN>; label = "right_green_2"; led-max-microamp = <3400>; };
		right_red_2: led@5 { reg = <0x5>; color = <LED_COLOR_ID_RED>; label = "right_red_2"; led-max-microamp = <3400>; };

		right_blue_3: led@6 { reg = <0x6>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_3"; led-max-microamp = <3400>; };
		right_green_3: led@7 { reg = <0x7>; color = <LED_COLOR_ID_GREEN>; label = "right_green_3"; led-max-microamp = <3400>; };
		right_red_3: led@8 { reg = <0x8>; color = <LED_COLOR_ID_RED>; label = "right_red_3"; led-max-microamp = <3400>; };

		right_blue_4: led@9 { reg = <0x9>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_4"; led-max-microamp = <3400>; };
		right_green_4: led@a { reg = <0xa>; color = <LED_COLOR_ID_GREEN>; label = "right_green_4"; led-max-microamp = <3400>; };
		right_red_4: led@b { reg = <0xb>; color = <LED_COLOR_ID_RED>; label = "right_red_4"; led-max-microamp = <3400>; };

		right_blue_5: led@c { reg = <0xc>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_5"; led-max-microamp = <3400>; };
		right_green_5: led@d { reg = <0xd>; color = <LED_COLOR_ID_GREEN>; label = "right_green_5"; led-max-microamp = <3400>; };
		right_red_5: led@e { reg = <0xe>; color = <LED_COLOR_ID_RED>; label = "right_red_5"; led-max-microamp = <3400>; };

		right_blue_6: led@f { reg = <0xf>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_6"; led-max-microamp = <3400>; };
		right_green_6: led@10 { reg = <0x10>; color = <LED_COLOR_ID_GREEN>; label = "right_green_6"; led-max-microamp = <3400>; };
		right_red_6: led@11 { reg = <0x11>; color = <LED_COLOR_ID_RED>; label = "right_red_6"; led-max-microamp = <3400>; };

		right_blue_7: led@12 { reg = <0x12>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_7"; led-max-microamp = <3400>; };
		right_green_7: led@13 { reg = <0x13>; color = <LED_COLOR_ID_GREEN>; label = "right_green_7"; led-max-microamp = <3400>; };
		right_red_7: led@14 { reg = <0x14>; color = <LED_COLOR_ID_RED>; label = "right_red_7"; led-max-microamp = <3400>; };

		right_blue_8: led@15 { reg = <0x15>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_8"; led-max-microamp = <3400>; };
		right_green_8: led@16 { reg = <0x16>; color = <LED_COLOR_ID_GREEN>; label = "right_green_8"; led-max-microamp = <3400>; };
		right_red_8: led@17 { reg = <0x17>; color = <LED_COLOR_ID_RED>; label = "right_red_8"; led-max-microamp = <3400>; };

		right_blue_9: led@18 { reg = <0x18>; color = <LED_COLOR_ID_BLUE>; label = "right_blue_9"; led-max-microamp = <3400>; };
		right_green_9: led@19 { reg = <0x19>; color = <LED_COLOR_ID_GREEN>; label = "right_green_9"; led-max-microamp = <3400>; };
		right_red_9: led@1a { reg = <0x1a>; color = <LED_COLOR_ID_RED>; label = "right_red_9"; led-max-microamp = <3400>; };
	};
};

&gpi_dma0 {
	status = "okay";
};

&gpu {
	status = "okay";

	interconnects = <&bimc MASTER_GRAPHICS_3D RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
	interconnect-names = "gfx-mem";

	zap-shader {
		firmware-name = "qcom/qrb4210/a610_zap.mbn";
	};
};

&gpu_opp_table {
	opp-320000000 {
		opp-peak-kBps = < 2188000>;
	};
	opp-465000000 {
		opp-peak-kBps = < 3072000>;
	};
	opp-600000000 {
		opp-peak-kBps = < 4068000>;
	};
	opp-745000000 {
		opp-peak-kBps = < 6220000>;
	};
	opp-820000000 {
		opp-peak-kBps = < 6220000>;
	};
	opp-900000000 {
		opp-peak-kBps = < 7216000>;
	};
	opp-950000000 {
		opp-peak-kBps = < 7216000>;
	};
	opp-980000000 {
		opp-peak-kBps = < 7216000>;
	};
	opp-1050000000 {
		opp-peak-kBps = < 8368000>;
	};
};

&cpu_bwmon_opp_table {
	opp-10 { opp-peak-kBps = <8368000>; };
};

&mdss {
	status = "okay";

	interconnects = <&mmrt_virt MASTER_MDP_PORT0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>,
			<&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &config_noc SLAVE_DISPLAY_CFG RPM_ACTIVE_TAG>;
};

&venus {
	firmware-name = "qcom/venus-6.0/venus.mbn";
	status = "okay";
};

&mdss_dsi0 {
	vdda-supply = <&vreg_l18a_1p232>;
	status = "okay";

	panel: panel@0 {
		reg = <0>;

		vdd1-supply = <&vreg_l9a_1p8>;
		vsp-supply = <&panel_avdd_outp>;
		vsn-supply = <&panel_avdd_outn>;
		backlight = <&panel_backlight>;

		enable-gpios = <&tlmm 97 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&tlmm 82 GPIO_ACTIVE_LOW>;

		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&mdss_dsi_active>, <&mdp_vsync_active>;
		pinctrl-1 = <&mdss_dsi_suspend>, <&mdp_vsync_suspend>;

		rotation = <270>;
		status = "okay";

		port {
			panel_in: endpoint {
				remote-endpoint = <&mdss_dsi0_out>;
			};
		};
	};
};

&mdss_dsi0_out {
	data-lanes = <0 1 2 3>;
	remote-endpoint = <&panel_in>;
};

&mdss_dsi0_phy {
	status = "okay";
};

&pm6125_gpios {
	vol_up_n: vol-up-n-state {
		pins = "gpio5";
		function = "normal";
		power-source = <0>;
		bias-pull-up;
		input-enable;
	};
};

&pm6125_pwm {
	status = "okay";
};

&pon_pwrkey {
	status = "okay";
};

&pon_resin {
	linux,code = <KEY_VOLUMEDOWN>;
	status = "okay";
};

&qupv3_id_0 {
	status = "okay";

	uart0: serial@4a80000 {
		compatible = "qcom,geni-uart";
		reg = <0x0 0x04a80000 0x0 0x4000>;
		interrupts-extended = <&intc GIC_SPI 327 IRQ_TYPE_LEVEL_HIGH>;
		clocks = <&gcc GCC_QUPV3_WRAP0_S0_CLK>;
		clock-names = "se";
		power-domains = <&rpmpd SM6115_VDDCX>;
		operating-points-v2 = <&qup_opp_table>;
		interconnects = <&clk_virt MASTER_QUP_CORE_0 RPM_ALWAYS_TAG
				 &clk_virt SLAVE_QUP_CORE_0 RPM_ALWAYS_TAG>,
				<&bimc MASTER_AMPSS_M0 RPM_ALWAYS_TAG
				 &config_noc SLAVE_QUP_0 RPM_ALWAYS_TAG>;
		interconnect-names = "qup-core", "qup-config";
		pinctrl-0 = <&qup_uart0_active>;
		pinctrl-1 = <&qup_uart0_sleep>;
		pinctrl-names = "default", "sleep";
	};
};

&remoteproc_adsp {
	firmware-name = "qcom/qrb4210/adsp.mbn";
	status = "okay";
};

&remoteproc_cdsp {
	firmware-name = "qcom/qrb4210/cdsp.mbn";
	status = "okay";
};

&remoteproc_mpss {
	firmware-name = "qcom/qrb4210/modem.mbn";
	status = "okay";
};

