&sdc2_state_off {
	cd-pins {
		pins = "gpio88";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};
};

&sdc2_state_on {
	cd-pins {
		pins = "gpio88";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
	};
};

&sdhc_1 {
        vmmc-supply = <&vreg_l24a_2p96>;
        vqmmc-supply = <&vreg_l11a_1p8>;

        non-removable;
        supports-cqe;
        cap-mmc-hw-reset;
        mmc-ddr-1_8v;
        mmc-hs200-1_8v;
        mmc-hs400-1_8v;
        mmc-hs400-enhanced-strobe;

        status = "okay";
};

&sdhc_2 {
	cd-gpios = <&tlmm 88 GPIO_ACTIVE_LOW>;
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&sdc2_state_on>;
	pinctrl-1 = <&sdc2_state_off>;
	vmmc-supply = <&vreg_l22a_2p96>;
	vqmmc-supply = <&vreg_l5a_2p96>;
	no-sdio;
	no-mmc;

	sd-uhs-sdr12;
	sd-uhs-sdr25;
	sd-uhs-sdr50;
	sd-uhs-sdr104;
	sd-uhs-ddr50;

	status = "okay";
};

&sleep_clk {
	clock-frequency = <32764>;
};

&lpass_tlmm {

	lpi_i2s2_active: lpi-i2s2-active-state {
		sck-pins {
			pins = "gpio10";
			function = "i2s2_clk";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};

		ws-pins {
			pins = "gpio11";
			function = "i2s2_ws";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};

		data0-pins {
			pins = "gpio12";
			function = "i2s2_data";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};

		data1-pins {
			pins = "gpio13";
			function = "i2s2_data";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};
	};

	lpi_qua_mi2s_active: lpi-qua-mi2s-active-state {
		sck-pins {
			pins = "gpio0";
			function = "qua_mi2s_sclk";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};

		ws-pins {
			pins = "gpio1";
			function = "qua_mi2s_ws";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};

		data0-pins {
			pins = "gpio2";
			function = "qua_mi2s_data";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};

		data1-pins {
			pins = "gpio3";
			function = "qua_mi2s_data";
			bias-pull-down;
			drive-strength = <2>;
			input-enable;
		};
	};

	lpi_ext_mclk0_b_active: lpi-ext_mclk0_b-active-state {
		mclk-pins {
			pins = "gpio5";
			function = "ext_mclk0_b";
			bias-disable;
			drive-strength = <4>;
			output-high;
		};
	};

	lpi_dmic23_active: lpi-dmic23-active-state {
		clk-pins {
			pins = "gpio8";
			function = "dmic23_clk";
			bias-disable;
			drive-strength = <8>;
			output-high;
		};

		data-pins {
			pins = "gpio9";
			function = "dmic23_data";
			bias-pull-down;
			drive-strength = <8>;
			input-enable;
		};
	};
};

&spi2 {
	status = "okay";
};

&tlmm {
	mdp_vsync_active: mdp-vsync-active-state {
		pins = "gpio81";
		function = "mdp_vsync";
		drive-strength = <2>;
		bias-pull-down;
	};

	mdp_vsync_suspend: mdp-vsync-suspend-state {
		pins = "gpio81";
		function = "mdp_vsync";
		drive-strength = <2>;
		bias-pull-down;
	};

	mdss_dsi_active: dsi-active-state {
		pins = "gpio82";
		function = "gpio";
		drive-strength = <8>;
		bias-disable;
	};

	mdss_dsi_suspend: dsi-suspend-state {
		pins = "gpio82";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
	};

	qup_uart0_active: qup-uart0-active-state {
		pins = "gpio2", "gpio3";
		function = "qup0";
		drive-strength = <6>;
		bias-pull-up;
	};

	qup_uart0_sleep: qup-uart0-sleep-state {
		pins = "gpio2", "gpio3";
		function = "qup0";
		drive-strength = <2>;
		bias-disable;
	};

	mcu_joy_default: mcu-joy-default-state {
		ctrl_pins {
			pins = "gpio22", "gpio25", "gpio26", "gpio27", "gpio28";
			function = "gpio";
			drive-strength = <2>;
			bias-disable;
		};

		btn_pins {
			pins = "gpio18", "gpio24", "gpio34", "gpio36";
			function = "gpio";
			drive-strength = <2>;
			bias-pull-up;
		};
	};

	uart3_default: uart3-default-state {
		cts-pins {
			pins = "gpio8";
			function = "qup3";
			drive-strength = <2>;
			bias-bus-hold;
		};

		rts-pins {
			pins = "gpio9";
			function = "qup3";
			drive-strength = <2>;
			bias-disable;
		};

		tx-pins {
			pins = "gpio10";
			function = "qup3";
			drive-strength = <2>;
			bias-disable;
		};

		rx-pins {
			pins = "gpio11";
			function = "qup3";
			drive-strength = <2>;
			bias-pull-up;
		};
	};

	uart3_sleep: uart3-sleep-state {
		cts-pins {
			pins = "gpio8";
			function = "gpio";
			drive-strength = <2>;
			bias-bus-hold;
		};

		rts-pins {
			pins = "gpio9";
			function = "gpio";
			drive-strength = <2>;
			bias-pull-down;
		};

		tx-pins {
			pins = "gpio10";
			function = "gpio";
			drive-strength = <2>;
			bias-pull-up;
		};

		rx-pins {
			pins = "gpio11";
			function = "gpio";
			drive-strength = <2>;
			bias-pull-up;
		};
	};

	sw_ctrl_default: sw-ctrl-default-state {
		pins = "gpio87";
		function = "gpio";
		bias-pull-down;
	};

	gpio_clk_pins: gpio-clk-pins {
		pins = "gpio86";
		function = "gcc_gp1";
		drive-strength = <8>;
		bias-disable;
	};

	vibra_vcc_default: vibra-vcc-default {
		function = "gpio";
		pins = "gpio96";
		drive-strength = <8>;
		output-high;
		bias-pull-up;
	};

	led_en_default: led-en-default {
		function = "gpio";
		pins = "gpio23";
		drive-strength = <8>;
		bias-pull-up;
		output-high;
	};

	rgbr_activate: rgbr-activate {
		function = "gpio";
		pins = "gpio37";
		drive-strength = <8>;
		bias-pull-up;
	};

	rgbr_suspend: rgbr-suspend {
		function = "gpio";
		pins = "gpio37";
		drive-strength = <2>;
		bias-disable;
	};

	rgbl_activate: rgbl-activate {
		function = "gpio";
		pins = "gpio21";
		drive-strength = <8>;
		bias-pull-up;
	};

	rgbl_suspend: rgbl-suspend {
		function = "gpio";
		pins = "gpio21";
		drive-strength = <2>;
		bias-disable;
	};

	es8326_irq_default: es8326-irq-default-state {
		pins = "gpio65";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
		input-enable;
	};

	es8326_vdd_default: es8326-vdd-default-state {
		pins = "gpio66";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	aw88261_left_irq_default: aw88261-left-irq-default-state {
		pins = "gpio106";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
		input-enable;
	};

	aw88261_right_irq_default: aw88261-right-irq-default-state {
		pins = "gpio107";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
		input-enable;
	};

	ts_irq_default: ts-irq-default-state {
		pins = "gpio69";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
	};

	ts_reset_default: ts-reset-default-state {
		pins = "gpio68";
		function = "gpio";
		drive-strength = <2>;
		bias-disable;
		output-low;
	};

	tcpc_irq_default: tcpc-irq-default-state {
		pins = "gpio39";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
		input-enable;
	};

	chg_int_default: chg-int-default-state {
		pins = "gpio70";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-up;
		input-enable;
	};

	chg_en_default: chg-en-default-state {
		pins = "gpio85";
		function = "gpio";
		drive-strength = <2>;
		bias-pull-down;
		output-low;
	};
};

&usb {
	status = "okay";
	assigned-clock-rates = <19200000>, <133333333>;
};

&usb_dwc3 {
	dr_mode = "otg";
	maximum-speed = "super-speed";

	ports {
		port@0 {
			usb_dwc3_hs: endpoint {
				remote-endpoint = <&usb_con_hs>;
			};
		};
	};
};

&usb_hsphy {
	vdd-supply = <&vreg_l4a_0p9>;
	vdda-pll-supply = <&vreg_l12a_1p8>;
	vdda-phy-dpdm-supply = <&vreg_l15a_3p128>;

	status = "okay";
};

&usb_qmpphy {
	vdda-phy-supply = <&vreg_l4a_0p9>;
	vdda-pll-supply = <&vreg_l12a_1p8>;

	status = "okay";

	ports {
		port@0 {
			usb_qmpphy_out: endpoint {
				remote-endpoint = <&usb_con_ss>;
			};
		};
	};
};

&wifi {
	/* SoC */
	vdd-0.8-cx-mx-supply = <&vreg_l8a_0p664>;

	/* WiFi / BT PMU */
	vdd-1.8-xo-supply = <&vreg_pmu_xo>;
	vdd-1.3-rfa-supply = <&vreg_pmu_rf>;
	vdd-3.3-ch0-supply = <&vreg_pmu_ch0>;

	status = "okay";
};

&uart0 {
	gamepad {
		compatible = "rocknix,mangmi-air-x-joypad";
		pinctrl-names = "default";
		pinctrl-0 = <&mcu_joy_default>;
		mcu-power-gpios = <&tlmm 25 GPIO_ACTIVE_HIGH>;
		mcu-reset-gpios = <&tlmm 26 GPIO_ACTIVE_HIGH>;
		mcu-boot0-gpios = <&tlmm 27 GPIO_ACTIVE_HIGH>;
		mcu-boot1-gpios = <&tlmm 28 GPIO_ACTIVE_HIGH>;
		stick-en-gpios  = <&tlmm 22 GPIO_ACTIVE_HIGH>;

		mcu-start-gpios  = <&tlmm 18 GPIO_ACTIVE_LOW>;
		mcu-select-gpios = <&tlmm 24 GPIO_ACTIVE_LOW>;
		mcu-mode-gpios   = <&tlmm 36 GPIO_ACTIVE_LOW>;
		mcu-back-gpios   = <&tlmm 34 GPIO_ACTIVE_LOW>;
	};
};

&uart3 {
	interrupts-extended = <&intc GIC_SPI 330 IRQ_TYPE_LEVEL_HIGH>,
			      <&tlmm 11 IRQ_TYPE_EDGE_FALLING>;
	pinctrl-0 = <&uart3_default>;
	pinctrl-1 = <&uart3_sleep>;
	pinctrl-names = "default", "sleep";
	status = "okay";

	bluetooth {
		compatible = "qcom,wcn3950-bt";

		vddio-supply = <&vreg_pmu_io>;
		vddxo-supply = <&vreg_pmu_xo>;
		vddrf-supply = <&vreg_pmu_rf>;
		vddch0-supply = <&vreg_pmu_ch0>;
		max-speed = <3200000>;
	};
};

&uart4 {
	status = "okay";
};

&xo_board {
	clock-frequency = <19200000>;
};

&gpu_thermal {
	cooling-maps {
		map0 {
			trip = <&gpu_alert0>;
			cooling-device =
				<&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>,
				<&gpu THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
		map1 {
			trip = <&gpu_fan>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
	};

	trips { gpu_fan: gpu-fan { temperature = <65000>; hysteresis = <5000>; type = "active"; }; };
};

&cpu0123_thermal {
	cooling-maps {
		map0 {
			trip = <&cpu0123_alert0>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
		map1 {
			trip = <&cpu0123_alert1>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
		map2 {
			trip = <&cpu0123_fan>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
	};

	trips { cpu0123_fan: cpu0123-fan { temperature = <65000>; hysteresis = <5000>; type = "active"; }; };
};

&cpu45_thermal {
	cooling-maps {
		map0 {
			trip = <&cpu45_alert0>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
		map1 {
			trip = <&cpu45_alert1>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
		map2 {
			trip = <&cpu45_fan>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
	};

	trips { cpu45_fan: cpu45-fan { temperature = <65000>; hysteresis = <5000>; type = "active"; }; };
};

&cpu67_thermal {
	cooling-maps {
		map0 {
			trip = <&cpu67_alert0>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
		map1 {
			trip = <&cpu67_alert1>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
		map2 {
			trip = <&cpu67_fan>;
			cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
		};
	};

	trips { cpu67_fan: cpu67-fan { temperature = <65000>; hysteresis = <5000>; type = "active"; }; };
};

/ {
	cpu0_opp_table: opp-table-cpu0 {
		compatible = "operating-points-v2";
		opp-shared;

		opp-300000000  { opp-hz = /bits/ 64 < 300000000>; opp-peak-kBps = <  800000>; };
		opp-614400000  { opp-hz = /bits/ 64 < 614400000>; opp-peak-kBps = < 2188000>; };
		opp-864000000  { opp-hz = /bits/ 64 < 864000000>; opp-peak-kBps = < 3072000>; };
		opp-1017600000 { opp-hz = /bits/ 64 <1017600000>; opp-peak-kBps = < 3072000>; };
		opp-1305600000 { opp-hz = /bits/ 64 <1305600000>; opp-peak-kBps = < 3072000>; };
		opp-1420800000 { opp-hz = /bits/ 64 <1420800000>; opp-peak-kBps = < 4068000>; };
		opp-1612800000 { opp-hz = /bits/ 64 <1612800000>; opp-peak-kBps = < 4068000>; };
		opp-1804800000 { opp-hz = /bits/ 64 <1804800000>; opp-peak-kBps = < 4068000>; };
		opp-2016000000 { opp-hz = /bits/ 64 <2016000000>; opp-peak-kBps = < 6220000>; };
	};

	cpu4_opp_table: opp-table-cpu4 {
		compatible = "operating-points-v2";
		opp-shared;

		opp-300000000  { opp-hz = /bits/ 64 < 300000000>; opp-peak-kBps = <  800000>; };
		opp-652800000  { opp-hz = /bits/ 64 < 652800000>; opp-peak-kBps = < 2188000>; };
		opp-902400000  { opp-hz = /bits/ 64 < 902400000>; opp-peak-kBps = < 2188000>; };
		opp-1056000000 { opp-hz = /bits/ 64 <1056000000>; opp-peak-kBps = < 4068000>; };
		opp-1401600000 { opp-hz = /bits/ 64 <1401600000>; opp-peak-kBps = < 4068000>; };
		opp-1536000000 { opp-hz = /bits/ 64 <1536000000>; opp-peak-kBps = < 6220000>; };
		opp-1612800000 { opp-hz = /bits/ 64 <1612800000>; opp-peak-kBps = < 6220000>; };
		opp-1804800000 { opp-hz = /bits/ 64 <1804800000>; opp-peak-kBps = < 6220000>; };
		opp-2016000000 { opp-hz = /bits/ 64 <2016000000>; opp-peak-kBps = < 7216000>; };
		opp-2112000000 { opp-hz = /bits/ 64 <2112000000>; opp-peak-kBps = < 8368000>; };
	};

	thermal-zones {
		battery-thermal {
			polling-delay-passive = <5000>;
			polling-delay = <10000>;
			thermal-sensors = <&fuel_gauge>;
			linux,governor = "bang_bang";

			trips {
				battery_fan_on: battery-fan-on {
					temperature = <40000>;
					hysteresis = <5000>;
					type = "active";
				};
			};

			cooling-maps {
				map0 {
					trip = <&battery_fan_on>;
					cooling-device = <&fan THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
				};
			};
		};
	};
};

&cpu0 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu0_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
&cpu1 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu0_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
&cpu2 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu0_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
&cpu3 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu0_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
&cpu4 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu4_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
&cpu5 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu4_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
&cpu6 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu4_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
&cpu7 {
	#cooling-cells = <2>;
	operating-points-v2 = <&cpu4_opp_table>;
	interconnects = <&bimc MASTER_AMPSS_M0 RPM_ACTIVE_TAG
			 &bimc SLAVE_EBI_CH0 RPM_ACTIVE_TAG>;
};
