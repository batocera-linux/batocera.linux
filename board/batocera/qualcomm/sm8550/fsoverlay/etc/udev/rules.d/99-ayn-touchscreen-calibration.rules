# -----------------------------------------------------------------------------
# AYN Thor dual-screen touchscreen calibration
# -----------------------------------------------------------------------------

# Bottom physical touchscreen (platform-98c000.i2c)
SUBSYSTEM=="input", KERNEL=="event*", \
  ENV{ID_INPUT_TOUCHSCREEN}=="1", \
  ENV{ID_PATH}=="platform-98c000.i2c", \
  ENV{LIBINPUT_CALIBRATION_MATRIX}="0.645833 0 0.177083 0 0.5 0.5"

# Top physical touchscreen (a90000.i2c -> i2c-4)
SUBSYSTEM=="input", KERNEL=="event*", \
  ENV{ID_INPUT_TOUCHSCREEN}=="1", \
  DEVPATH=="*/a90000.i2c/i2c-4/*", \
  ENV{LIBINPUT_CALIBRATION_MATRIX}="1 0 0 0 0.5 0"

# -----------------------------------------------------------------------------
# AYN Odin 2 Portal touchscreen
# -----------------------------------------------------------------------------

# Single touchscreen (a90000.i2c -> i2c-3)
SUBSYSTEM=="input", KERNEL=="event*", \
  ENV{ID_INPUT_TOUCHSCREEN}=="1", \
  DEVPATH=="*/a90000.i2c/i2c-3/*", \
  ENV{LIBINPUT_CALIBRATION_MATRIX}="0 -1 1 1 0 0"
