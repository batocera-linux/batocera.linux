# Batocera-specific kernel config fragment for Odroid M2
# Applied on top of the Armbian rockchip64 base defconfig

# Required for Batocera squashfs rootfs overlay boot
# Armbian has these as modules, but Batocera needs them built-in
# since the rootfs itself is a squashfs mounted via overlayfs
CONFIG_OVERLAY_FS=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y

# Required for evmapy (gamepad-to-keyboard mapping)
# Must be built-in, not a module, for early availability
CONFIG_INPUT_UINPUT=y

# USB-C dual role support (host + device via fusb302)
CONFIG_USB_DWC3_DUAL_ROLE=y
CONFIG_USB_ROLE_SWITCH=y

# Disable kernel boot logo (Batocera uses its own splash)
# CONFIG_LOGO is not set
